{* macro testa_estamos_a_caminho() *}
    
    /*
        1. Achar um fórmula que indique se o programa
        a) está à caminho da posição destino
        b) chegou à posição destino
        c) passou da posição destino
        - Se passou da posição destino, então, mude o sentido
        2. Achar um número que indique a distância da posição destino
        a) se for maior que 0, estamos à caminho
        b) se for igual a zero, chegamos no destino
        c) se for menor que 0, passamos do destino
        3. Este número será a imagem de uma função d(s,x,z,X,Z,D)
        a) d representa a distância do destino
        b) s representa o sentido, que pode ser left ou right
        c) x e z representam, respectivamente, a posição X e Z do destino
        d) X e Z representam, respectivamente, a posição do player
        e) D é a direção assumida pelo player
    */
    
    /*
        A variável #diferenca_eixo mostra a soma das diferenças das coordenadas X e Z
        Como sempre uma das coordenadas ou X ou Z são iguais entre o player e o destino,
        então, um dos termos da expressão atribuída a #diferenca_eixo sempre sera igual a zero.
        Como consequência, o módulo de #diferenca_eixo sempre indicará a distância do player ao destino.
        Basta verificarmos a relação entre sinal de #diferenca_eixo, sentido e direção para os eventos:
        1. está a caminho da posição destino
        2. passou da posição destino
        Estudando a relação direção-sentido-sinal-evento:
        N:
        right:
        - passamos
        + estamos a caminho
        left
        - estamos a caminho
        + passamos
        S:
        right:
        - estamos a caminho
        + passamos
        left
        - passamos
        + estamos a caminho
        E:
        right:
        - passamos
        + estamos a caminho
        left
        - estamos a caminho
        + passamos
        W:
        right:
        - estamos a caminho
        + passamos
        left
        - pa ssou
        + estamos a caminho
    */
    
    {*
        set testes = [
            {
                'direção':'N',
                'sentido':'right',
                'sinal':'positivo'
            },
            {
                'direção':'N',
                'sentido':'left',
                'sinal':'negativo'
            },
            
            
            {
                'direção':'S',
                'sentido':'right',
                'sinal':'negativo'
            },
            {
                'direção':'S',
                'sentido':'left',
                'sinal':'positivo'
            },
            
            
            {
                'direção':'E',
                'sentido':'right',
                'sinal':'positivo'
            },
            {
                'direção':'E',
                'sentido':'left',
                'sinal':'negativo'
            },
            
            
            {
                'direção':'W',
                'sentido':'right',
                'sinal':'negativo'
            },
            {
                'direção':'W',
                'sentido':'left',
                'sinal':'positivo'
            }
            
        ]
    *}
    
    DO(1);
        {* for teste in testes *}
            
            {{ testa_estamos_a_caminho_passou(direção=teste.direção,sentido=teste.sentido,sinal_esperado=teste.sinal) }}
            
        {* endfor *}
    LOOP;
    LOG("§a§lTODOS OS TESTES PASSARAM AQUI!");
    
{* endmacro *}

