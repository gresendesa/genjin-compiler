/*
    
    OBJETIVO:
    DESCRIÇÃO: Esta macro implementará um loop que seguirá o seguinte algoritmo:
    1. o player será movido até o baú e coluna indicados na direção e no sentido definidos
    2. olhará para o baú e executará a operação.
    3. o baú será incrementado e o look será atualizado para o novo baú. Exceto se
    o baú for o último. Neste caso, o número do baú será reiniciado para o
    início, e o player será movido 1 coluna na direção e sentido definidos. vá para 2
    
    A operação realizará função de gestão entre baú e inventário. A operação decidirá
    quando o loop deverá ser quebrado.
    
    Para a operação será passado: o baú, a coluna, direção, sentido, e regex_id e variável_resposta
    O último baú e última coluna utilizada pelo loop serão informados, respectivamente
    variável_bau, variável_colunas
    
    Caso player seja impedido de movimentar-se em função de fim de passarela,
    então a variável_sucesso será definida como 'false' e o loop será quebrado.
    DEV: Jeff, TonNSz, Federal
    
    
    Sexo: macho ou fêmea ou hermafrodita (definido no nascimento) (imutável)
    Gênero: homem, mulher (diferente de sexualidade) (papel social)
    Opção sexual: heterossexual, homossexual, bissexual, panssexual...
    
    DISCLAIMER: Senhorita namorada do Federal, eu Jeff Hinoto me abstenho completamente desse tipo de assunto e nego ter qualquer relação com tal ocorrido.
    
    * hook_acessar_baú(outvar='consegui_abrir'): recebe uma macro que abre o baú e indica se ele foi fechado
    * hook_fechar_inventário(outvar='consegui_fechar'): recebe uma macro que fecha o baú e indica se ele foi fechado
    
*/
{* set gr = nid() *}

{* macro hook_acessar_baú(success_outvar, baú) *}
    
    UNSET({{ success_outvar }});
    IFMATCHES(%HITID%,"{{ '^'~ids_baús|join('$|^')~'$' }}");
        {* set lados_permitidos_baús = ['N','S','E','W'] *}
        IFMATCHES(%HITSIDE%,"{{ '^'~lados_permitidos_baús|join('$|^')~'$' }}");
            #distancex{{ gr }}=XPOS-HITX;
            #distancez{{ gr }}=ZPOS-HITZ;
            #distancesum{{ gr }}=#distancex{{ gr }}+#distancez{{ gr }};
            MATCH("%#distancesum{{ gr }}%","-?([0-9]+)",#distance{{ gr }},1);//Pega a distância absoluta até o baú
            IF(#distance{{ gr }}==2);
                DO;
                    INC(#count{{ gr }}abrir,1);
                    IFMATCHES(%GUI%,CHEST);
                        SET({{ success_outvar }});
                        BREAK;
                    ELSE;
                        IF(#count{{ gr }}abrir>50);
                            BREAK;
                        ENDIF;
                        KEYUP(SNEAK);
                        KEY(USE);
                        WAIT(10t);
                    ENDIF;
                LOOP;
                UNSET(#count{{ gr }}abrir);
            ELSE;
                LOG("§e✘ §8baú na distância incorreta");
            ENDIF;
        ELSE;
            LOG("§e✘ §8baú mal colocado");
        ENDIF;
    ELSE;
        LOG("§e✘ §8não é báu");
    ENDIF;
    
{* endmacro *}

{* macro hook_fechar_inventário(success_outvar, baú) *}
    
    UNSET({{ success_outvar }});
    DO;
        IFMATCHES(%GUI%,NONE);
            SET({{ success_outvar }});
            BREAK;
        ELSE;
            GUI();
        ENDIF;
        WAIT(5t);
    LOOP;
    
{* endmacro *}

//HERE <- itera_mkb
{*
    macro itera_mkb(
        operação,
        regex_id='^.*$',
        baú='%@#bau%',
        coluna='%@#coluna%',
        direção='%DIRECTION%',
        sentido='right',
        variável_resposta='&resposta'~gr,
        variável_baú='@#bau',
        variável_coluna='@#coluna',
        variável_sucesso='success'~gr,
        passo=1,
        quantidade=0,
        limite_baús=0,
        hook_abrir_baú=hook_acessar_baú,
        hook_fechar_baú=hook_fechar_inventário,
        hook_executar_ao_iniciar=None,
        hook_executar_ao_finalizar=None,
        informação_útil=None,
        delay=0,
        distância_cautelar=0,
        turbo=None
    )
*}

{* set r = nid() *}

SET(#bau{{ r }},{{ baú }});
SET(#distancia{{ r }},{{ coluna }});
UNSET(#coluna{{ r }});
UNSET(#baus_verificados{{ r }});
UNSET({{ variável_resposta }});

{* if hook_executar_ao_iniciar is callable *}
    {{ hook_executar_ao_iniciar(baú=baú, coluna=coluna, direção=direção, sentido=sentido, regex_id=regex_id, variável_resposta=variável_resposta, variável_baú=variável_baú, variável_coluna=variável_coluna, quantidade=quantidade, limite_baús=limite_baús, baús_verificados='%#baus_verificados'~r~'%', delay=delay, informação_útil=informação_útil) }}
{* endif *}

DO;
    {* if this.protocol == 'CTRL' *}
        {* import 'Macrosoft.cortex.common' as CORTEX *}
        {{ CORTEX.loop() }}
    {* endif *}
    #distancia{{ r }}=#distancia{{ r }}*{{ passo}};//alteração feita para pular mais de uma fileira por vez na MKB
    {{ jeffwalk(direção=direção, sentido=sentido, distância='%#distancia'~r~'%', variável_sucesso=variável_sucesso, distância_cautelar=distância_cautelar) }}
    INC(#coluna{{ r }},%#distancia{{ r }}%);//Isso indicará a quantidade de colunas percorridas
    {* if turbo != None *}
        {{ 'UNSAFE('~ turbo ~')' }};
    {* endif *}
    /**
        * Modificação feita dia 10/02/2025
        *
        * Após 4 anos, 3 apocalipses e 1 guerra mundial, voltamos aqui para dizer que tá tudo bem e o mundo não é mais o mesmo.
        * Com ChatGPT, Gemini e o novo DeepSeek, nós meros fazedore de macros estamos passando fome e vendendo macro feito agua,
        * o que por sinal é contraditório, não?
        *
        * deixo aqui minha anotação salva pro meu eu de 40 anos de que tá tudo certo pra dar errado, se vira pra arruar aí <3
        *
        * Jeff, Tony, Federal todos discordam mas "na minha máquina funciona"
    */
    IF({{ variável_sucesso }});
        #front{{ r}}=2;
        #right{{ r}}=0;
        #up{{ r}}=3-#bau{{ r}};//varia de -1 a 3
        #x{{ r}}=(((DIRECTION=="E")-(DIRECTION=="W"))*(#front{{ r}}))+(((DIRECTION=="N")-(DIRECTION=="S"))*(#right{{ r}}))+XPOS;
        #y{{ r}}=YPOS+#up{{ r}};
        #z{{ r}}=(((DIRECTION=="S")-(DIRECTION=="N"))*(#front{{ r}}))+(((DIRECTION=="E")-(DIRECTION=="W"))*(#right{{ r}}))+ZPOS;
        GETID(%#x{{ r}}%,%#y{{ r}}%,%#z{{ r}}%,&id_bloco{{ r}});
        UNSET(abriu{{ r}});
        IFMATCHES("%&id_bloco{{ r}}%","{{ '^'~ids_baús|join('$|^')~'$' }}")
            {{ olha_baú(número='%#bau'~r~'%') }}
            {* if hook_abrir_baú is callable *}
                {{ hook_abrir_baú(success_outvar='abriu'~r, baú='%#bau'~r~'%') }}
            {* else *}
                SET(abriu{{ r }});
            {* endif *}
        endif;
        IF(abriu{{ r }});//Para se não conseguir abrir ele vai pular pra o próximo
            
            {{ operação(baú='%#bau'~r~'%', coluna='%#coluna'~r~'%', direção=direção, sentido=sentido, regex_id=regex_id, variável_resposta=variável_resposta, variável_baú=variável_baú, variável_coluna=variável_coluna, quantidade=quantidade, limite_baús=limite_baús, baús_verificados='%#baus_verificados'~r~'%', delay=delay, informação_útil=informação_útil) }}
            
            {* if hook_fechar_baú is callable*}
                {{ hook_fechar_baú(success_outvar='fechou'~r, baú='%#bau'~r~'%') }}
            {* else *}
                SET(fechou{{ r }});
            {* endif *}
            
            IF(!fechou{{ r }});//Para se não conseguir fechar o báu e indica falta de sucesso no processo
                UNSET({{ variável_sucesso }});
                BREAK;
            ENDIF;
        ENDIF;
        UNSET(#distancia{{ r }});//Isso volta a coluna pra 0
        UNSET(bottom_reached{{ r }});
        INC(#bau{{ r }},1);//Incrementando o baú
        
        IF(#bau{{ r }}>4);
            SET(#bau{{ r }},4);
            SET(bottom_reached{{ r }});
        ENDIF;
        //IF(#bau{{ r }}>4);
        //	UNSET(#bau{{ r }});//Isso retorna o baú para 0
        //	INC(#distancia{{ r }},1);//Isso faz a macro andar uma posição no sentido definido
        //ENDIF;
        
        /**
         * Federal em 18/10/2025, às 1:06 da madrugada.
         * --> Correção de parâmetro "quantidade" <--
         * MKBs incompletas (com colunas com vãos) estavam causando mau funcionamento do MKB itera.
         * Quando desenhamos isso, imaginamos que a coluna sempre teria 5 baús de altura.
         * No entanto, em algum momento entre 2024 e 2025, Jeff e eu fizemos o programa
         * ignorar posições da coluna onde o baú não estivesse. Não imaginávamos, porém,
         * que isso traria um efeito colateral que seria resolvido apenas no fim.
         * de outubro de 2025 (com a ajuda do Gemini!)
         * Quando o primeiro baú não existia no topo, o programa considerava que
         * um baú tinha sido lido. E por isso, uma variável crítica (#quantidade_faltando) nunca era inicializada.
         * FEITO! BONITO! SIMPLES e IRRITANTE!
         */
        //INC(#baus_verificados{{ r }},1); <-- 18/10/2025: comentado: 
        //Correção abaixo:
        IF(abriu{{ r }});//Só avalia como verdade se o báu da iteração foi aberto!
            INC(#baus_verificados{{ r }},1); //<-- a execução agora é condicional
        ENDIF;
        
        IF(({{ limite_baús }}>0)&&(#baus_verificados{{ r }}=={{ limite_baús }}));
            //LOG("§8§llimit reached §7(§8{{ limite_baús }}§7)");
            LOG("§a✓ §8limite de baús alcançado");
            BREAK;
        ENDIF;
        
        IF(bottom_reached{{ r }});
            UNSET(#bau{{ r }});//Isso retorna o baú para 0
            INC(#distancia{{ r }},1);//Isso faz a macro andar uma posição no sentido definido
        ENDIF;
        
    ELSE;
        
        LOG("§e✘ §8fim da passarela");
        BREAK;//Isso para a macro se o cara chegou no fim da passarela
        
    ENDIF;
    
    {* if turbo != None *}
        {{ 'ENDUNSAFE' }};
    {* endif *}
    
LOOP;

{* if hook_fechar_baú is callable *}
    {{ hook_fechar_baú(success_outvar='fechou'~r, baú='%#bau'~r~'%') }}
{* else *}
    SET(fechou{{ r }});
{* endif *}

IF(({{ variável_sucesso }})&&(!fechou{{ r }}));//Para se não conseguir fechar o báu e indica falta de sucesso no processo
    UNSET({{ variável_sucesso }});
ENDIF;

//Essas variáveis nos informarão em que local da mkb a operação parou
SET({{ variável_baú }},%#bau{{ r }}%);
SET({{ variável_coluna }},%#coluna{{ r }}%);

{* if hook_executar_ao_finalizar is callable *}
    {{ hook_executar_ao_finalizar(baú='%#bau'~r~'%', coluna='%#coluna'~r~'%', direção=direção, sentido=sentido, regex_id=regex_id, variável_resposta=variável_resposta, variável_baú=variável_baú, variável_coluna=variável_coluna, quantidade=quantidade, limite_baús=limite_baús, baús_verificados='%#baus_verificados'~r~'%', delay=delay, informação_útil=informação_útil) }}
{* endif *}

{* endmacro *}

{* macro _op_apanhar_abstrata(slot_inicio, slot_fim, baú, coluna, direção, sentido, regex_id, variável_resposta, variável_baú, variável_coluna, quantidade, limite_baús, baús_verificados, obstrução_outvar, delay, informação_útil, quantidade_movidos_outvar=None) *}
    
    //adicionar inicio, fim e quantidade
    //inicio: variável que definirá onde o slot_inicio será definido
    //fim: variável que definirá onde o slot_fim será definido
    //quantidade: definirá a quantidade de itens a serem movidas
    {* set r = nid() *}
    
    IF(!{{ baús_verificados }});//Isso será executado sempre no início da operação
        //LOG("Beleza, resetei");
        SET(#quantidade_inicial{{ r }},{{ quantidade }});
        SET(#quantidade_faltando{{ r }},{{ quantidade }});
    ENDIF;
    
    UNSET(#quantidade{{ r }});
    
    {{ olha_baú(número=baú) }}
    
    {{
        GUI.itera(
            operação=GUI.op_apanhar,
            slot_inicio=slot_inicio,
            slot_fim=slot_fim,
            errorvar=obstrução_outvar,
            quantidade='%#quantidade_faltando'~r~'%',
            regex_id=regex_id,
            outvar='#quantidade'~r,
            delay=delay
        )
    }}
    
    SET({{ quantidade_movidos_outvar }},%#quantidade{{ r }}%);
    
    INC({{ variável_resposta }},%#quantidade{{ r }}%);
    
    DEC(#quantidade_faltando{{ r }},%#quantidade{{ r }}%);
    
    IF(({{ quantidade }}!=0)&&(#quantidade_faltando{{ r }}<=0));
        //IF((#quantidade_inicial{{ r }}!=0)&&(#quantidade_faltando{{ r }}<=0));//Tentativa de resolver em 10/8/21
        BREAK;//Para de fazer
    ENDIF;
    
{* endmacro *}


