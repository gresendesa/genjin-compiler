{* set ids_baús = ['54','chest','146','trapped_chest','130','ender_chest'] *}
//HERE <- jeffwalk
{* macro jeffwalk(direção="%DIRECTION%", sentido="right", distância=1, variável_sucesso='success', blocos_proibidos=['0','air','31','grass','6','sapling','37','flower','38','rose','39','40','torch','50'], distância_cautelar=0) *}
    
    {* set rand = nid() *}
    
    {* macro gera_código_direção(para, dir, var_eixo_constante, var_eixo_variável, variações) *}
        
        #dir{{ rand }}={{ dir }};
        {{ var_eixo_constante }}{{ rand }}=0;
        //#destinoz=ZPOS;
        {* if para == 'left' *}
            {{ var_eixo_variável }}{{ rand }}={{ variações[1] }};
        {* elif para == 'right' *}
            {{ var_eixo_variável }}{{ rand }}={{ variações[0] }};
        {* else *}
            ifmatches("{{ para }}","right");
                {{ var_eixo_variável }}{{ rand }}={{ variações[0] }};
            else;
                {{ var_eixo_variável }}{{ rand }}={{ variações[1] }};
            endif;
        {* endif *}
        
    {* endmacro *}
    
    {*
        set configs = {
            'N':{
                'dir': 0,
                'var_eixo_constante': '#variacaoz',
                'var_eixo_variável': '#variacaox',
                'variações': [1, -1]
            },
            'S':{
                'dir': 180,
                'var_eixo_constante': '#variacaoz',
                'var_eixo_variável': '#variacaox',
                'variações': [-1, 1]
            },
            'E':{
                'dir': 90,
                'var_eixo_constante': '#variacaox',
                'var_eixo_variável': '#variacaoz',
                'variações': [1, -1]
            },
            'W':{
                'dir': 270,
                'var_eixo_constante': '#variacaox',
                'var_eixo_variável': '#variacaoz',
                'variações': [-1, 1]
            }
        }
    *}
    
    /*
        Essa pequenina e intrincada macro, gera as flags que indicam se o avatar deve
        andar para a direta e se o sinal da distância esperada é positiva.
        esses parâmetros são definidos somente em função so sentido e dos valores passados como argumento
    */
    {* macro gerar_direita_positivo(sentido,rdireita,rpositiva,ldireita,lpositiva) *}
        
        {* if sentido == 'right' *}
            SET(andar_direita{{ rand }});
            {* if rpositiva *}
                SET(distancia_positiva{{ rand }});
            {* else *}
                UNSET(distancia_positiva{{ rand }});
            {* endif *}
        {* elif sentido == 'left' *}
            UNSET(andar_direita{{ rand }});
            {* if lpositiva *}
                SET(distancia_positiva{{ rand }});
            {* else *}
                UNSET(distancia_positiva{{ rand }});
            {* endif *}
        {* else *}
            IF({{ sentido }}=="right");
                SET(andar_direita{{ rand }});
                {* if rpositiva *}
                    SET(distancia_positiva{{ rand }});
                {* else *}
                    UNSET(distancia_positiva{{ rand }});
                {* endif *}
            ELSE;
                UNSET(andar_direita{{ rand }});
                {* if lpositiva *}
                    SET(distancia_positiva{{ rand }});
                {* else *}
                    UNSET(distancia_positiva{{ rand }});
                {* endif *}
            ENDIF;
        {* endif *}
        
    {* endmacro *}
    
    //LOG("LOG SEGURO DIREÇÃO: {{ direção }}");
    //HERE <- voltar
    {* if direção == 'N' *}
        
        //LOG("é N literal");
        {{ gera_código_direção(para=sentido, dir=configs.N.dir, var_eixo_constante=configs.N.var_eixo_constante, var_eixo_variável=configs.N.var_eixo_variável, variações=configs.N.variações) }}
        {{ gerar_direita_positivo(sentido=sentido,rpositiva=True,lpositiva=False) }}
        
    {* elif direção == 'S' *}
        
        //LOG("é S literal");
        {{ gera_código_direção(para=sentido, dir=configs.S.dir, var_eixo_constante=configs.S.var_eixo_constante, var_eixo_variável=configs.S.var_eixo_variável, variações=configs.S.variações) }}
        {{ gerar_direita_positivo(sentido=sentido,rpositiva=False,lpositiva=True) }}
        
    {* elif direção == 'E' *}
        
        //LOG("é E literal");
        {{ gera_código_direção(para=sentido, dir=configs.E.dir, var_eixo_constante=configs.E.var_eixo_constante, var_eixo_variável=configs.E.var_eixo_variável, variações=configs.E.variações) }}
        {{ gerar_direita_positivo(sentido=sentido,rpositiva=True,lpositiva=False) }}
        
    {* elif direção == 'W' *}
        
        //LOG("é W literal");
        {{ gera_código_direção(para=sentido, dir=configs.W.dir, var_eixo_constante=configs.W.var_eixo_constante, var_eixo_variável=configs.W.var_eixo_variável, variações=configs.W.variações) }}
        {{ gerar_direita_positivo(sentido=sentido,rpositiva=False,lpositiva=True) }}
        
    {* else *}
        
        if({{ direção }}=="N");
            
            //LOG("é N");
            {{ gera_código_direção(para=sentido, dir=configs.N.dir, var_eixo_constante=configs.N.var_eixo_constante, var_eixo_variável=configs.N.var_eixo_variável, variações=configs.N.variações) }}
            {{ gerar_direita_positivo(sentido=sentido,rpositiva=True,lpositiva=False) }}
            
            
        elseif({{ direção }}=="S");
            
            //LOG("é S");
            {{ gera_código_direção(para=sentido, dir=configs.S.dir, var_eixo_constante=configs.S.var_eixo_constante, var_eixo_variável=configs.S.var_eixo_variável, variações=configs.S.variações) }}
            {{ gerar_direita_positivo(sentido=sentido,rpositiva=False,lpositiva=True) }}
            
            
        elseif({{ direção }}=="E");
            
            //LOG("é E");
            {{ gera_código_direção(para=sentido, dir=configs.E.dir, var_eixo_constante=configs.E.var_eixo_constante, var_eixo_variável=configs.E.var_eixo_variável, variações=configs.E.variações) }}
            {{ gerar_direita_positivo(sentido=sentido,rpositiva=True,lpositiva=False) }}
            
        elseif({{ direção }}=="W");
            
            //LOG("é W");
            {{ gera_código_direção(para=sentido, dir=configs.W.dir, var_eixo_constante=configs.W.var_eixo_constante, var_eixo_variável=configs.W.var_eixo_variável, variações=configs.W.variações) }}
            {{ gerar_direita_positivo(sentido=sentido,rpositiva=False,lpositiva=True) }}
            
        endif;
        
    {* endif *}
    
    #destinox{{ rand }}=XPOS+({{ distância }}*#variacaox{{ rand }});
    #destinoz{{ rand }}=ZPOS+({{ distância }}*#variacaoz{{ rand }});
    //log(X:%#destinox{{ rand }}% Z:%#destinoz{{ rand }}%)
    SET(#pitch_congelado{{ rand }},%PITCH%);
    CENTEROVERBLOCK();
    WAIT(3t);
    do;
        
        {* if this.protocol == 'CTRL' *}
            {* import 'Macrosoft.cortex.common' as CORTEX *}
            {{ CORTEX.loop() }}
        {* endif *}
        
        look(%#dir{{ rand }}%,%#pitch_congelado{{ rand }}%);
        
        GETIDREL(%#variacaox{{ rand }}%,-1,%#variacaoz{{ rand }}%,&bloco_lado{{ rand }});
        GETIDREL(%#variacaox{{ rand }}%,0,%#variacaoz{{ rand }}%,&bloco_lado0{{ rand }});
        GETIDREL(%#variacaox{{ rand }}%,1,%#variacaoz{{ rand }}%,&bloco_lado1{{ rand }});
        
        //LOG(%&bloco_lado{{ rand }}%);
        
        /*
            1. Achar um fórmula que indique se o programa
            a) está à caminho da posição destino
            b) chegou à posição destino
            c) passou da posição destino
            - Se passou da posição destino, então, mude o sentido
            2. Achar um número que indique a distância da posição destino
            a) se for maior que 0, estamos à caminho
            b) se for igual a zero, chegamos no destino
            c) se for menor que 0, passamos do destino
            3. Este número será a imagem de uma função d(s,x,z,X,Z,D)
            a) d representa a distância do destino
            b) s representa o sentido, que pode ser left ou right
            c) x e z representam, respectivamente, a posição X e Z do destino
            d) X e Z representam, respectivamente, a posição do player
            e) D é a direção assumida pelo player
        */
        
        /*
            A variável #diferenca_eixo mostra a soma das diferenças das coordenadas X e Z
            Como sempre uma das coordenadas ou X ou Z são iguais entre o player e o destino,
            então, um dos termos da expressão atribuída a #diferenca_eixo sempre sera igual a zero.
            Como consequência, o módulo de #diferenca_eixo sempre indicará a distância do player ao destino.
            Basta verificarmos a relação entre sinal de #diferenca_eixo, sentido e direção para os eventos:
            1. está a caminho da posição destino
            2. passou da posição destino
            Estudando a relação direção-sentido-sinal-evento:
            N:
            right:
            - passamos
            + estamos a caminho
            left
            - estamos a caminho
            + passamos
            S:
            right:
            - estamos a caminho
            + passamos
            left
            - passamos
            + estamos a caminho
            E:
            right:
            - passamos
            + estamos a caminho
            left
            - estamos a caminho
            + passamos
            W:
            right:
            - estamos a caminho
            + passamos
            left
            - passou
            + estamos a caminho
        */
        
        #diferenca_eixo{{ rand }}=(#destinox{{ rand }}-XPOS)+(#destinoz{{ rand }}-ZPOS);
        
        //Pega a diferença absoluta
        #abs_diferenca_eixo{{ rand }}=#diferenca_eixo{{ rand }};
        IF(#diferenca_eixo{{ rand }}<0);
            #abs_diferenca_eixo{{ rand }}=#diferenca_eixo{{ rand }}*-1;
        ENDIF;
        //LOG(%#diferenca_eixo{{ rand }}%);
        
        //LOG("andar direita: %andar_direita{{ rand }}%");
        //LOG("distancia_positiva: %distancia_positiva{{ rand }}%");
        IF(((#diferenca_eixo{{ rand }}>0)&&(!distancia_positiva{{ rand }}))||((#diferenca_eixo{{ rand }}<0)&&(distancia_positiva{{ rand }})));
            TOGGLE(andar_direita{{ rand }});
            TOGGLE(distancia_positiva{{ rand }});
            #variacaox{{ rand }}=#variacaox{{ rand }}*-1;//Inverte a variação, já que o sentido e invertido
            #variacaoz{{ rand }}=#variacaoz{{ rand }}*-1;//Inverte a variação, já que o sentido e invertido
            LOG("§e✘ §8woops");
            KEYUP("right");
            KEYUP("left");
            {* if distância_cautelar > 0 *}
                KEYUP("sneak");
            {* endif *}
            WAIT(1t);
        ELSEIF(#diferenca_eixo{{ rand }}==0);
            SET({{ variável_sucesso }});
            BREAK;
        ENDIF;
        
        IFMATCHES("%&bloco_lado{{ rand }}%","{{ '^' + blocos_proibidos | join('$|^') + '$' }}");
            UNSET({{ variável_sucesso }});
            BREAK;
        ENDIF;
        
        {* import 'Federal.sense.sensor' as SENSOR *}
        //Isso espera que tenha blocos proibidos (blocos não sólidos) para que ela possa passar por entre eles
        IFMATCHES("{%&bloco_lado0{{ rand }}%}{%&bloco_lado1{{ rand }}%}","{{ SENSOR.regexp_has_ids(ids=blocos_proibidos, only=True) }}");
            SET({{ variável_sucesso }});
        ELSE;
            UNSET({{ variável_sucesso }});
            BREAK;
        ENDIF;
        
        //Anda agachado se estiver perto
        {* if distância_cautelar > 0 *}
            IF(#abs_diferenca_eixo{{ rand }}<={{ distância_cautelar }});
                KEYDOWN("sneak");
            ENDIF;
        {* endif *}
        
        IF(andar_direita{{ rand }});
            KEYDOWN("right");
        ELSE;
            KEYDOWN("left");
        ENDIF;
        WAIT(1t);//Não remova este atraso. É essencial para UNSAFE
        
    LOOP;
    KEYUP("right");
    KEYUP("left");
    {* if distância_cautelar > 0 *}
        KEYUP("sneak");
    {* endif *}
    WAIT(3t);
    CENTEROVERBLOCK();
    
{* endmacro *}
{* macro op_abre_bau_multiaccount(success_outvar, baú) *}
    if({{ baú }} = 0)
        #y = %YPOS% + 3;
    elseif({{ baú }} = 1)
        #y = %YPOS% + 2;
    elseif({{ baú }} = 2)
        #y = %YPOS% + 1;
    elseif({{ baú }} = 3)
        #y = %YPOS%;
    elseif({{ baú }} = 4)
        #y = %YPOS% - 1;
    endif;
    if(%DIRECTION% = "N")
        #z = %ZPOS% - 2;
        #x = %XPOS%;
    elseif(%DIRECTION% = "S")
        #z = %ZPOS% + 2;
        #x = %XPOS%;
    elseif(%DIRECTION% = "W")
        #x = %XPOS% - 2;
        #z = %ZPOS%;
    elseif(%DIRECTION% = "E")
        #x = %XPOS% + 2;
        #z = %ZPOS%;
    endif;
    UNSET({{ success_outvar }});
    DO;
        INC(#count{{ gr }}abrir,1);
        IFMATCHES(%GUI%,CHEST);
            SET({{ success_outvar }});
            BREAK;
        ELSE;
            IF(#count{{ gr }}abrir>50);
                BREAK;
            ENDIF;
            KEYUP(SNEAK);
            simulaterightclick(%#x%,%#y%,%#z%,t);
            WAIT(10t);
        ENDIF;
    LOOP;
    UNSET(#count{{ gr }}abrir);
{* endmacro *}
{* macro testa_estamos_a_caminho_passou(direção,sentido,sinal_esperado) *}
    
    {*
        set configs = {
            'N':{
                'dir': 0,
                'var_eixo_constante': '#variacaoz',
                'var_eixo_variável': '#variacaox',
                'variações': {
                    'right':1,
                    'left':-1
                }
            },
            'S':{
                'dir': 180,
                'var_eixo_constante': '#variacaoz',
                'var_eixo_variável': '#variacaox',
                'variações': {
                    'right':-1,
                    'left':1
                }
            },
            'E':{
                'dir': 90,
                'var_eixo_constante': '#variacaox',
                'var_eixo_variável': '#variacaoz',
                'variações': {
                    'right':1,
                    'left':-1
                }
            },
            'W':{
                'dir': 270,
                'var_eixo_constante': '#variacaox',
                'var_eixo_variável': '#variacaoz',
                'variações': {
                    'right':-1,
                    'left':1
                }
            }
        }
    *}
    
    LOOK({{ configs[direção].dir }},0);
    WAIT(10t);
    UNSET(#variacaox);
    UNSET(#variacaoz);
    INC({{ configs[direção].var_eixo_variável }},{{ configs[direção].variações[sentido] }});
    #destinox=XPOS+#variacaox;
    #destinoz=ZPOS+#variacaoz;
    SET(&sinal,"{{ sinal_esperado }}");
    #diferenca_eixo=(#destinox-XPOS)+(#destinoz-ZPOS);
    IF((#diferenca_eixo>0)&&(&sinal=="positivo"));
        LOG("§a§lsucesso com {{ direção }}+{{ sentido }}+positivo");
    ELSEIF((#diferenca_eixo<0)&&(&sinal=="negativo"));
        LOG("§a§lsucesso com {{ direção }}+{{ sentido }}+negativo");
    ELSEIF((#diferenca_eixo==0));
        LOG("§c§linssucesso com {{ direção }}+{{ sentido }}. Sem sinal. Igual a 0");
        BREAK;
    ELSE;
        LOG("§c§linssucesso com {{ direção }}+{{ sentido }} está {{ sinal_esperado }}");
        BREAK;
    ENDIF;
    
{* endmacro *}

