{* macro _op_descarregar_abstrata(slot_inicio, slot_fim, baú, coluna, direção, sentido, regex_id, variável_resposta, variável_baú, variável_coluna, quantidade, limite_baús, baús_verificados, informação_útil, delay) *}
    
    {* set r = nid() *}
    
    IF(!{{ baús_verificados }});//Isso será executado sempre no início da operação
        //LOG("Beleza, resetei");
        SET(#quantidade_faltando{{ r }},{{ quantidade }});
    ENDIF;
    
    UNSET(#quantidade{{ r }});
    
    {{ olha_baú(número=baú) }}
    
    {{
        GUI.itera(
            operação=GUI.op_descarregar,
            slot_inicio=slot_inicio,
            slot_fim=slot_fim,
            errorvar='obstrucao'~r,
            quantidade='%#quantidade_faltando'~r~'%',
            regex_id=regex_id,
            outvar='#quantidade'~r,
            delay=delay
        )
    }}
    
    INC({{ variável_resposta }},%#quantidade{{ r }}%);
    
    DEC(#quantidade_faltando{{ r }},%#quantidade{{ r }}%);
    
    IF(({{ quantidade }}!=0)&&(#quantidade_faltando{{ r }}<=0));
        BREAK;
    ENDIF;
    
    //IF((!obstrucao{{ r }})&&(!#quantidade{{ r }}));
    IF(!obstrucao{{ r }});
        LOG("§a✓ §8não há mais itens para mover");
        BREAK;
    ELSE;
        LOG("§e⚠ §8baú cheio");
    ENDIF;
    
{* endmacro *}

