{* macro macromod_variable_renderer(CORE, variable, jinja_out_var) *}
	{* if variable[ATTRIBUTE.TYPE] == TYPE.LOGIC *}
		{* set prefix = '' *}
	{* elif variable[ATTRIBUTE.TYPE] == TYPE.NUMBER *}
		{* set prefix = '#' *}
	{* elif variable[ATTRIBUTE.TYPE] == TYPE.TEXT *}
		{* set prefix = '&' *}
	{* else *}
		{{ raise("Variable '"~variable[ATTRIBUTE.NAME]~"' has type '"~variable[ATTRIBUTE.TYPE]~"' which is not allowed! Use just LOGIC, NUMBER or TEXT") }}
	{* endif *}
	{* set _ = jinja_out_var.update({ATTRIBUTE.NAME: prefix~variable[ATTRIBUTE.NAME]~variable[ATTRIBUTE.ID]}) *}
{* endmacro *}

{* macro macromod_set_variable(CORE, variable, value) *}
	{* set mapping_var = {} *}
	{{ CORE.language.render_variable_name(CORE=CORE, variable=variable, jinja_out_var=mapping_var) }}
	{* set variable_name = mapping_var[ATTRIBUTE.NAME] *}
	{* if variable[ATTRIBUTE.TYPE]==TYPE.TEXT *}
		SET({{ variable_name }},"{{ value }}");
	{* else *}
		SET({{ variable_name }},{{ value }});
	{* endif *}
{* endmacro *}

{* macro macromod_get_variable_value(CORE, variable, jinja_out_var) *}
	{* set mapping_var = {} *}
	{{ CORE.language.render_variable_name(CORE=CORE, variable=variable, jinja_out_var=mapping_var) }}
	{* set value_of_variable = '%'~mapping_var[ATTRIBUTE.NAME]~'%' *}
	{* set _ = jinja_out_var.update({ATTRIBUTE.VALUE: value_of_variable}) *}
{* endmacro *}

{* macro macromod_decision_structure_variable_value_equality_renderer(CORE, macro, variable, value, close_structure=True) *}
	
	{* set outvar_variable_dict = {} *}
	{{ CORE.language.render_variable_name(CORE=CORE, variable=variable, jinja_out_var=outvar_variable_dict) }}
	{* set variable_name_rendered = outvar_variable_dict[ATTRIBUTE.NAME] *}
	
	{* if variable[ATTRIBUTE.TYPE]==TYPE.TEXT *}
		{{ 'IF('~variable_name_rendered~'=="'~value~'");' }}
	{* else *}
		{{ 'IF('~variable_name_rendered~'=='~value~');' }}
	{* endif *}
	{{ macro(CORE) }}
	{* if close_structure *}
		{{ 'ENDIF;' }}
	{* endif *}
	
{* endmacro *}

{* macro macromod_decision_structure_variable_value_disjunction_renderer(CORE, macro, variable, values, close_structure=True) *}
	
	{* set outvar_variable_dict = {} *}
	{{ CORE.language.render_variable_name(CORE=CORE, variable=variable, jinja_out_var=outvar_variable_dict) }}
	{* set variable_name_rendered = outvar_variable_dict[ATTRIBUTE.NAME] *}
	
	{* set conditions = [] *}
	{* for value in values *}
		{* if variable[ATTRIBUTE.TYPE]==TYPE.TEXT *}
			{* set _ = conditions.append('('~variable_name_rendered~'=="'~value~'")') *}
		{* else *}
			{* set _ = conditions.append('('~variable_name_rendered~'=='~value~')') *}
		{* endif *}
	{* endfor *}
	
	{* if conditions|length > 0 *}
		{* if conditions|length > 1 *}
			{{ 'IF('~conditions|join('||')~');' }}
		{* else *}
			{{ 'IF'~conditions|join('||')~';' }}
		{* endif *}
		{{ macro(CORE) }}
		{* if close_structure *}
			{{ 'ENDIF;' }}
		{* endif *}
	{* else *}
		{!! Se por algum motivo a lista de valores estiver vazia, não renderiza nada !!}
	{* endif *}
	
{* endmacro *}

{* macro macromod_render_conditional_loop(CORE, macro, variable, codes) *}
	
	{* set outvar_variable_dict = {} *}
	{{ CORE.language.render_variable_name(CORE=CORE, variable=variable, jinja_out_var=outvar_variable_dict) }}
	{* set variable_name_rendered = outvar_variable_dict[ATTRIBUTE.NAME] *}
	
	{* set codes_é_list = [] *}
	{{ is_list(codes, codes_é_list) }}
	
	{* if codes_é_list[0] and codes | length > 0 *}
		{* set codes_rendered = [] *}
		{* set prefix = '(' *}
		{* set suffix = ')' *}
		{* if codes | length == 1 *}
			{* set prefix = '' *}
			{* set suffix = '' *}
		{* endif *}
		{* for code in codes *}
			{* if variable[ATTRIBUTE.TYPE]==TYPE.TEXT *}
				{* set _ = codes_rendered.append(prefix~variable_name_rendered~'=="'~code~'"'~suffix) *}
			{* else *}
				{* set _ = codes_rendered.append(prefix~variable_name_rendered~'=='~code~suffix) *}
			{* endif *}
		{* endfor *}
		DO;
			{{ macro() }}
		WHILE({{ codes_rendered | join('||') }});
	{* else *}
		{{ macro() }}
	{* endif *}
	
{* endmacro *}

