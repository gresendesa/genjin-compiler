//--utils
{* macro filter_list_objects(list_objects, attribute, value, jinja_out_var, attribute_of_attribute=None) *}
	{* for obj in list_objects *}
		{* if attribute_of_attribute is string *}
			{* if obj[attribute][attribute_of_attribute] == value *}
				{* set _ = jinja_out_var.append(obj) *}
			{* endif *}
		{* else *}
		{* endif *}
		{* if obj[attribute] == value *}
			{* set _ = jinja_out_var.append(obj) *}
		{* endif *}
	{* endfor *}
{* endmacro *}

{* macro is_list(value, jinja_list_out_var) *}
	{* if value is iterable and (value is not string and value is not mapping) *}
		{* set _ = jinja_list_out_var.append(True) *}
	{* else *}
		{* set _ = jinja_list_out_var.append(False) *}
	{* endif *}
{* endmacro *}

{* macro is_dict(value, jinja_list_out_var) *}
	{* if value is iterable and value is mapping *}
		{* set _ = jinja_list_out_var.append(True) *}
	{* else *}
		{* set _ = jinja_list_out_var.append(False) *}
	{* endif *}
{* endmacro *}


