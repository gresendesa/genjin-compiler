{* import "Federal.IBM.default" as IBM *}

{* macro constants() *}

  SET(&pim_syn_signal_,"PIM1SYN:");
  SET(&pim_ack_signal_,"PIM1ACK:");
  SET(&pim_return_signal_,"PIM1END:");
  
{* endmacro *}

{* macro requester(is_cloud=True) *}
	
	{{ constants() }}
	
	RANDOM(#pin,0,999999999);
	SET(&pim_socket_requester_,"@&pim1_%#pin%");
	
	//LOG("В§8В§l[IBM] В§e1. В§7(%&pim_socket_requester_%) Socket Created.");
	
  {{ IBM.parse_request(request_var='&ibm_request_', target_outvar='&target_file_', syn_message_outvar='&pim_syn_message_', args_outvar='&ibm_args_', snippets_outvar='&request_snippets_') }}
	
	//LOG("В§8В§l[IBM] В§erequest to file В§fВ§l%&target_file_%.txt В§asyn:%&pim_syn_message_% В§7%&ibm_args_[1]% %&ibm_args_[2]% %&ibm_args_[3]% %&ibm_args_[4]% %&ibm_args_[5]% %&ibm_args_[6]% %&ibm_args_[7]% %&ibm_args_[8]% %&ibm_args_[9]%");
	
	SET(%&pim_socket_requester_%,"%&pim_syn_signal_%%&pim_syn_message_%");
	
	SET(&pim_socket_requester_msg_,"%%&pim_socket_requester_%%");
	
	//LOG("В§8В§l[IBM] В§e2. В§7(%&pim_socket_requester_%) Syn Message Sent: В§f%&pim_socket_requester_msg_%");
	
	//EXEC("%&target_file_%.txt","%&target_file_%",%&ibm_args_[1]%,%&ibm_args_[2]%,%&ibm_args_[3]%,%&ibm_args_[4]%,%&ibm_args_[5]%,%&ibm_args_[6]%,%&ibm_args_[7]%,%&ibm_args_[8]%,%&ibm_args_[9]%,%&pim_socket_requester_%,%&ibm_args_[11]%,%&ibm_args_[12]%,%&ibm_args_[13]%,%&ibm_args_[14]%,%&ibm_args_[15]%);
	{* if is_cloud *}
		run("%&target_file_%",%&ibm_args_[1]%,%&ibm_args_[2]%,%&ibm_args_[3]%,%&ibm_args_[4]%,%&ibm_args_[5]%,%&ibm_args_[6]%,%&ibm_args_[7]%,%&ibm_args_[8]%,%&ibm_args_[9]%,%&pim_socket_requester_%,%&ibm_args_[11]%,%&ibm_args_[12]%,%&ibm_args_[13]%,%&ibm_args_[14]%,%&ibm_args_[15]%);
	{* else *}
		EXEC("%&target_file_%.exe","%&target_file_%",%&ibm_args_[1]%,%&ibm_args_[2]%,%&ibm_args_[3]%,%&ibm_args_[4]%,%&ibm_args_[5]%,%&ibm_args_[6]%,%&ibm_args_[7]%,%&ibm_args_[8]%,%&ibm_args_[9]%,%&pim_socket_requester_%,%&ibm_args_[11]%,%&ibm_args_[12]%,%&ibm_args_[13]%,%&ibm_args_[14]%,%&ibm_args_[15]%);
	{* endif *}

	#timeout_=500;
	IF(#api_request_timeout_>0);
		#timeout_=%#api_request_timeout_%;
	ENDIF;
	
	&pattern_ack_="^%&pim_ack_signal_%(.*)";
	&pattern_return_="^%&pim_return_signal_%(.*)";
	
	UNSET(#ibm_success_);
	UNSET(timeout_);
	UNSET(#count_loops_);
	UNSET(&ibm_response_);
	DO;
		
		INC(#count_loops_);
		
		IFMATCHES(%#count_loops_%,"^50$|^100$|^150$|^200$|^250$|^300$|^350$|^400$|^450$");
			LOG("В§8В§l[IBM] В§7connecting В§8to В§n%&target_file_% В§8В§o%#count_loops_%/%#timeout_%");
		ENDIF;
		
		SET(&pim_socket_requester_msg_,"%%&pim_socket_requester_%%");
		
		IF((#count_loops_>=%#timeout_%) || (KEY_DELETE));
			
			SET(timeout_);
			BREAK;
			
		ELSE;
			
			IFMATCHES(%&pim_socket_requester_msg_%,%&pattern_ack_%);
				
				MATCH(%&pim_socket_requester_msg_%,%&pattern_ack_%,{&pim_ack_message_});
				
				//LOG("В§8В§l[IBM] В§e5. В§7(%&pim_socket_requester_%) Ack Message Rcvd: В§f%&pim_socket_requester_msg_%");
				
				BREAK;
				
			ENDIF;
			
		ENDIF;
		
		WAIT(10ms);
		
	WHILE(#count_loops_<%#timeout_%);
	
	IF(timeout_);
		
		LOG("В§8В§l[IBM] В§7file В§fВ§l%&target_file_% В§4did not respond");
		
		WAIT(10ms);
		
	ELSE;
		
		SET(#ibm_success_,1);
		//LOG("В§8В§l[IBM] В§eConnection В§aOK");
		SET(&pim_socket_requester_msg_,"%%&pim_socket_requester_%%");
		DO;
			
			WAIT(10ms);
			
			SET(&pim_socket_requester_msg_,"%%&pim_socket_requester_%%");
			
			//LOG("%&pim_socket_requester_msg_%==%&last_ack_message_%");
			
			IFMATCHES(%&pim_socket_requester_msg_%,%&pattern_return_%);
				
				MATCH(%&pim_socket_requester_msg_%,%&pattern_return_%,{&ibm_response_});
				
				//LOG("В§8В§l[IBM] В§e7. В§7(%&pim_socket_requester_%) Response Message Rcvd: В§f%&pim_socket_requester_msg_%");
				
				MATCH(%&ibm_response_%,"(.*)",{#ibm_response_});
				
				BREAK;
				
			ENDIF;
			
		UNTIL(KEY_DELETE);
		//WHILE(&pim_socket_requester_msg_==%&last_ack_message_%);
		
		IF(KEY_DELETE);
			
			LOG("В§8В§l[IBM] В§7END pressed. Process aborted");
			
		ENDIF;
		
		WAIT(10ms);
		
		//LOG("В§8В§l[IBM] В§aSuccess. В§eTransaction finalized. В§fReturned В§7%&ibm_response_%");
		
	ENDIF;
	
	WAIT(100ms);
	UNSET("%&pim_socket_requester_%");
{* endmacro *}

{* macro stop() *}
  
  {{ constants() }}

	SET(&pim_socket_provider_msg_,"%%&pim_socket_provider_%%");
	&pattern_ack_="^%&pim_ack_signal_%(.*)";

	IF(#ibm_success_);

		IFMATCHES(%&pim_socket_provider_msg_%,%&pattern_ack_%);

		  SET(%&pim_socket_provider_%,"%&pim_return_signal_%%&ibm_return_%");

		  SET(&pim_socket_provider_msg_,"%%&pim_socket_provider_%%");

		  //LOG("В§8В§l[IBM] В§e6. В§7(%&pim_socket_provider_%) Response Message Sent: В§f%&pim_socket_provider_msg_%");

		ELSE;	

			//LOG("В§8В§l[IBM] В§fACK В§esignal expected. But В§f'В§7%&pim_socket_provider_msg_%В§f' В§emessage В§ewas В§efound В§einstead.");
			
			UNSET(%&pim_socket_provider_%);

		ENDIF;

		UNSET(#ibm_success_);

	ENDIF;

{* endmacro *}

{* macro start() *}
  
  MATCH("$$[1]Вў$$[2]Вў$$[3]Вў$$[4]Вў$$[5]Вў$$[6]Вў$$[7]Вў$$[8]Вў$$[9]Вў$$[10]Вў$$[11]Вў$$[12]Вў$$[13]Вў$$[14]Вў$$[15]","([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?",&inputs_[]);
  MATCH("$$[1]Вў$$[2]Вў$$[3]Вў$$[4]Вў$$[5]Вў$$[6]Вў$$[7]Вў$$[8]Вў$$[9]Вў$$[10]Вў$$[11]Вў$$[12]Вў$$[13]Вў$$[14]Вў$$[15]","([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?Вў([^Вў]*)?",#inputs_[]);

  &pim_socket_provider_="%&inputs_[10]%";

  {{ IBM.constants() }}
  {{ constants() }}

  SET(&pim_socket_provider_msg_,"%%&pim_socket_provider_%%");

  &pattern_syn_="^%&pim_syn_signal_%(.*)";

  IFMATCHES(%&pim_socket_provider_msg_%,%&pattern_syn_%);

    MATCH(%&pim_socket_provider_msg_%,%&pattern_syn_%,{&pim_syn_message_});

    //LOG("В§8В§l[IBM] В§e3. В§7(%&pim_socket_provider_%) Syn Message Rcvd: В§f%&pim_socket_provider_msg_%");

    SET(%&pim_socket_provider_%,"%&pim_ack_signal_%%&pim_ack_message_%");

    SET(&pim_socket_provider_msg_,"%%&pim_socket_provider_%%");

    //LOG("В§8В§l[IBM] В§e4. В§7(%&pim_socket_provider_%) Ack Message Sent: В§f%&pim_socket_provider_msg_%");

    WAIT(50ms);

    SET(#ibm_success_,1);

    IFMATCHES(%&pim_syn_message_%,"^%&ibm_syn_closeafter_msg_%$");

    	{{ stop() }}
    	
    ENDIF;

  ELSE;

    SET(#ibm_success_,0);
    
  ENDIF;

{* endmacro *}