/*
  NOME: parts/common/open_inventory.txt
  DESCRIÇÃO: 
*/
{* macro common_open_inventory() *}

  DO(10);
    IFMATCHES(%GUI%,INVENTORY);
      BREAK;
    ELSE;
    	WAIT(100ms);
      GUI(INVENTORY);
    ENDIF;
    IF(KEY_DELETE);
    	BREAK;
    ENDIF;
  LOOP;

{* endmacro *}

/*
  NOME: parts/common/open_chest.txt
  DESCRIÇÃO: 
*/
{* macro common_open_chest() *}

  DO(50);
    KEYUP(SNEAK);
    IFMATCHES(%GUI%,CHEST);
      BREAK;
    ELSE;
      KEYUP(SNEAK);
      KEY(USE);
      DO(20);
        KEYUP(SNEAK);
        WAIT(50ms);
        IFMATCHES(%GUI%,CHEST);
          BREAK;
        ENDIF;
      UNTIL(KEY_DELETE);
    ENDIF;
  UNTIL(KEY_DELETE);

{* endmacro *}

/*
  NOME: parts/common/keyendloop.txt
  DESCRIÇÃO: 
*/
{* macro common_keyendloop() *}

  IF((KEY_DELETE) || (keyendpressed_));
    LOG("§4§lKEY_DELETE pressed");
    SET(keyendpressed_);
    BREAK;
  ELSE;
    UNSET(keyendpressed_);
  ENDIF;
  
{* endmacro *}  

/*
  NOME: parts/common/getslotitem.txt
  DESCRIÇÃO: 
*/
{* macro common_getslotitem(countvar='#i') *}

  UNSET(&id);
  GETSLOTITEM(%{{ countvar }}%,&id,#stack,&damage);
  IF(!&id);
    GETSLOTITEM(%{{ countvar }}%,#id,#stack,#damage);
    MATCH("%#id%:%#damage%","([0-9]+):([0-9]+)",{&id,&damage});
  ENDIF;
  
{* endmacro *} 

/*
  NOME: parts/common/yaw_restore.txt
  DESCRIÇÃO: 
*/
{* macro common_yaw_restore() *}
  DO(10);
    LOOK(%#transformed_yaw%,%#frozen_pitch%,0.1);
    WAIT(10ms);
  UNTIL((%YAW%==%#untransformed_yaw%) || (KEY_DELETE));
{* endmacro *} 

/*
  NOME: parts/common/close_inventory.txt
  DESCRIÇÃO: 
*/
{* macro common_close_inventory() *}
  
  DO(10);
    IFMATCHES(%GUI%,NONE);
      BREAK;
    ELSE;
      GUI();
    ENDIF;
    IF(KEY_DELETE);BREAK;ENDIF;
    WAIT(100ms);
  LOOP;

{* endmacro *}

/*
  NOME: parts/common/yaw_save.txt
  DESCRIÇÃO: 
*/
{* macro common_yaw_save() *}
  
  #transformed_yaw=%YAW%-180;
  IF(%YAW%<180);
    #transformed_yaw=%YAW%+180;
  ENDIF;
  #frozen_pitch=%PITCH%

  #untransformed_yaw=%#transformed_yaw%-180;
  IF(#transformed_yaw<180);
    #untransformed_yaw=%#transformed_yaw%+180;
  ENDIF;

{* endmacro *}  

/*
  NOME: parts/common/pick_item.txt
  DESCRIÇÃO: 
*/
{* macro common_pick_item() *}

  //&item_list is the input
  UNSET(item_picked);
  FOR(#i_inv,1,9);
    UNSET(&id);
    GETSLOTITEM(%#i_inv%,&id,#stacksize,&data);
    IF(&id=="");
      GETSLOTITEM(%#i_inv%,#id,#stacksize,#data);
      MATCH("%#id%","[0-9]+",&id);
      //MATCH("%#data%","[0-9]+",&data);
    ENDIF;
    &item="%&id%";
    IFMATCHES("%&item%","%&item_list%");
      SLOT(%#i_inv%);
      #durability_left=((10000*%DURABILITY%)/(100*%ITEMDAMAGE%));
      //IF((DURABILITY<=0)||(#durability_left>10));
      IF((#durability_left>10) || (%DURABILITY%<0) || (%ITEM%=="air") || (%ITEM%=="0"));
        SET(item_picked);
        UNSET(break_);
        BREAK;
      ENDIF;
    ENDIF;
  NEXT;

{* endmacro *}
  

/*
  NOME: parts/common/sensor_directions.txt
  DESCRIÇÃO: 
*/
{* macro common_sensor_directions() *}

  IF(%DIRECTION%=="N");
    #x=0;#z=-1;       
  ELSEIF(%DIRECTION%=="S");
    #x=0;#z=1;
  ELSEIF(%DIRECTION%=="E");
    #x=1;#z=0;
  ELSEIF(%DIRECTION%=="W");
    #x=-1;#z=0;
  ENDIF;

{* endmacro *}

/*
  NOME: parts/common/.txt
  DESCRIÇÃO: 
*/
{* macro common_plugin_scanner() *}

  //&services="";
  //&plugin="";
  &ibm_request_="%&plugin%:info()";
  //{% "../../ibm/requester.txt" %}
  {{ MODULAR.ibm_requester() }}

  SET(services_ok);

  IF(#ibm_success_);
    SET(&info,%&ibm_response_%);
    MATCH(%&ibm_response_%,"([^,]+),?.*",{&author});
    DO;
      MATCH(%&services%,"([^,]*),?(.*)?",{&s,&o});
      SET(&services,%&o%);
      IF(&s);
        IFMATCHES(%&info%,",?%&s%,?");
          WAIT(1ms);
        ELSE;
          LOG("§8§l[SCANNER] §7service §f%&s% §4not found §7on §f%&plugin%");
          UNSET(services_ok);
          BREAK;
        ENDIF;
      ENDIF;
      WAIT(10ms);
    WHILE(&s);
  ELSE;
    UNSET(services_ok);
  ENDIF;

  IF(services_ok);
    LOG("§8§l[SCANNER] §f%&plugin% §8§9by %&author% §aOK.");
  ENDIF;

{* endmacro *}


/*
  NOME: parts/common/near_direction.txt
  DESCRIÇÃO: 
*/
{* macro common_near_direction() *}

  IF(%YAW%<=45);
    #direction=0;//South
  ELSEIF(%YAW%<=135);
    #direction=90;//West
  ELSEIF(%YAW%<=225);
    #direction=180;//North
  ELSEIF(%YAW%<=315);
    #direction=270;//East
  ELSE;
    #direction=0;//South
  ENDIF;

{* endmacro *}

/*
  NOME: parts/common/daytimestamp.txt
  DESCRIÇÃO: 
*/
{* macro common_daytimestamp() *}

  //SET(&time,"%TIME%");
  MATCH(%&time%,"([0-9]{2}):([0-9]{2}):([0-9]{2})",#groups[]);
  SET(#hour,%#groups[1]%);
  SET(#minute,%#groups[2]%);
  SET(#second,%#groups[3]%);
  #daytimestamp=(%#hour%*3600)+(%#minute%*60)+%#second%;
  //LOG("%&time% %#hour% : %#minute% : %#second%  == %#daytimestamp%");

{* endmacro *}

/*
  NOME: parts/common/mkb_around.txt
  DESCRIÇÃO: 
*/
{* macro common_mkb_around() *}

  //{% "sensor.directions.txt" %}
  {{ common_sensor_directions() }}

  #nx=%#x%*%#dir%*2;
  #nz=%#z%*%#dir%*2;

  GETIDREL(2,0,0,"&id_","&data_");
  SET(&a0,"%&id_%"); 
  GETIDREL(2,1,0"&id_","&data_");
  SET(&a1,"%&id_%"); 

  GETIDREL(-2,0,0,"&id_","&data_");
  SET(&b0,"%&id_%"); 
  GETIDREL(-2,1,0,"&id_","&data_");
  SET(&b1,"%&id_%"); 

  GETIDREL(0,0,2,"&id_","&data_");
  SET(&c0,"%&id_%"); 
  GETIDREL(0,1,2,"&id_","&data_");
  SET(&c1,"%&id_%"); 

  GETIDREL(0,0,-2,"&id_","&data_");
  SET(&d0,"%&id_%"); 
  GETIDREL(0,1,-2,"&id_","&data_");
  SET(&d1,"%&id_%"); 

  SET(&chest,"146|54|trapped_chest|chest");

  UNSET(mkbtrap_around);
  IFMATCHES("<{%&a0%}{%&a1%}><{%&b0%}{%&b1%}><{%&c0%}{%&c1%}><{%&d0%}{%&d1%}>",".*<\{%&chest%\}\{%&chest%\}>.*");
    SET(mkbtrap_around);
  ENDIF;

{* endmacro *}



