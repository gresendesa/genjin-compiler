/*
  NOME: parts/onchat/restart/client_snippet.txt
  DESCRIÇÃO: 
*/
{* macro onchat_restart_client_snippet() *}
  
  SET(&time,"%TIME%");
  //{% "../../common/daytimestamp.txt" %}
  {{ common_daytimestamp() }}
  #diff=%#daytimestamp%-%@#macrosoft_last_restart%;
  MATCH("%#diff%","-?([0-9]+)",{#abs_diff_restart});
  SET(#seconds_limit,15);
  #overflow_seconds_limit=86400-%#seconds_limit%;
  IF((#abs_diff_restart<=#seconds_limit) || (#abs_diff_restart>=#overflow_seconds_limit));//Verifica se o programa de reinício foi executado a no máximo 15 segundos atrás
    LOG("§7§lrestart_flag §8§l%#abs_diff_restart%s");
    SET(restart_flag);
  ELSE;
    UNSET(restart_flag);
  ENDIF;
  
{* endmacro *}

/* =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
  -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
  -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
  -======           HERE <- WOOD            ======-
  -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
  -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
  
  goto -> break_trunk
  goto -> clear_leaves
  goto -> centralize
  goto -> build_support
  goto -> check_tools
  goto -> scanner_above
  goto -> collects
  goto -> fertilize
  goto -> plants
*/
  
/*
  NOME: parts/wood/break_trunk.txt
  DESCRIÇÃO: 
  HERE <- break_trunk
*/
{* macro wood_break_trunk() *}

  DO(50);
  	
    SET(&hit_message,"%%&hit_socket%%"); 

    IFMATCHES(%&hit_message%,"^missing_tool$");
      SET(hit_issue);
      BREAK;
    ELSE;
      &sensor=%HITID%;
      WAIT(50ms);
    ENDIF;

    //{% "../../modular/loop.txt" %}
    {{ MODULAR.modular_loop() }}

  UNTIL((&sensor!="17") && (&sensor!="log"));

{* endmacro *}

/*
  NOME: parts/wood/clear_leaves.txt
  DESCRIÇÃO: 
  HERE <- clear_leaves
*/
{* macro wood_clear_leaves() *}
  
  WAIT(200ms);
  #transformed_yaw=%YAW%-180;
  IF(%YAW%<180);
    #transformed_yaw=%YAW%+180;
  ENDIF;
  #frozen_pitch=%PITCH%;

  DO(100);
    LOOK(,90,0.1);
    IFMATCHES(%HITID%,"18|leaves");
      CAPTUREFOCUS();
      KEY(ATTACK);
      WAIT(10ms);
    ELSE;
      BREAK;
    ENDIF;
  UNTIL(KEY_DELETE);

  DO(10);
    LOOK(%#transformed_yaw%,%#frozen_pitch%,0.1);
    WAIT(10ms);
  UNTIL((%YAW%==%#untransformed_yaw%) || (KEY_DELETE));

{* endmacro *}

/*
  NOME: parts/wood/centralize.txt
  DESCRIÇÃO: 
  HERE <- centralize
*/
{* macro wood_centralize() *}
  
  IFMATCHES(%HITID%,"18|leaves");
    //{% "clear_leaves.txt" %}
    {{ wood_clear_leaves() }}
  ENDIF;

  IF(HASINTEL);
    CENTEROVERBLOCK();
  ELSE;
    FOR(#i,1,4);
      IF(#i==1);
        &interact_="ON(%&service_socket%) NOTWRITE() AND WAIT UNTIL(paused)";
      ELSEIF(#i==2);
        &interact_="ON(%&service_socket%) WRITE(resume:center) AND WAIT UNTIL(resumed)";
      ELSEIF(#i==3);
        &interact_="ON(%&service_socket%) NOTWRITE() AND WAIT WHILE(resumed)";
      ELSEIF(#i==4);
        &interact_="ON(%&service_socket%) WRITE(ok. thanks) AND WAIT UNTIL(paused)";
      ENDIF;
      //{ "../../modular/socket.interact.txt" }
      {{ MODULAR.modular_socket_interact() }}
    NEXT;
  ENDIF;

{* endmacro *}

/*
  NOME: parts/wood/build_support.txt
  DESCRIÇÃO: 
  HERE <- build_support
*/
{* macro wood_build_support() *}

  FOR(#bravo,1,3);
    IF(#bravo==1);

      &interact_="ON(%&hit_socket%) WRITE(pause: ok. thanks) AND WAIT UNTIL(paused)";

    ELSEIF(#bravo==2);

      //{% "centralize.txt" %}
      {{ wood_centralize() }}

      IF(!hit_issue);

        #targety=%YPOS%+%#wood_above%-7;

        UNSET(wood_not_found);
        DO(50);

          PICK("17","log");

          IFMATCHES(%ITEM%,"17|log");//Looks towards floor and build support
            LOOK(,90);
            KEYDOWN(JUMP);
            KEY(USE);
          ELSE;
            //picks wood
            FOR(#alpha,1,4);
              IF(#alpha==1);
                &interact_="ON(%&service_socket%) NOTWRITE() AND WAIT UNTIL(paused)";
              ELSEIF(#alpha==2);
                &interact_="ON(%&service_socket%) WRITE(resume:picker,17|log=>4) AND WAIT UNTIL(resumed)";
              ELSEIF(#alpha==3);
                &interact_="ON(%&service_socket%) NOTWRITE() AND WAIT WHILE(resumed)";
              ELSEIF(#alpha==4);
                IFMATCHES(%&interact_message_%,"^not_available|^low_durability");
                  LOG("§e'§3Wood§e' §6There'no log available");
                  SET(wood_not_found);
                ENDIF;
                &interact_="ON(%&service_socket%) WRITE(ok. thanks) AND WAIT UNTIL(paused)";
              ENDIF;
              //{% "../../modular/socket.interact.txt" %}
              {{ MODULAR.modular_socket_interact() }}
            NEXT;
          ENDIF;

          WAIT(100ms);
          GETIDREL(0,-1,0,&id_below,&data_below);

          IFMATCHES(%&id_below%,"17|log");
            IF(%YPOS%==%#targety%);
              BREAK;
            ENDIF;
          ENDIF;

        UNTIL((KEY_DELETE) || (wood_not_found));

        KEYUP(JUMP);

        LOOK(,270,0.3);

        &interact_="ON(%&hit_socket%) WRITE(resume:17|log,%&axe_list%,attack) AND WAIT UNTIL(resumed)";

      ELSE;

        //LOG("break at 2/3");
        BREAK;

      ENDIF;
    
    ELSEIF(#bravo==3);

      //{% "break_trunk.txt" %}
      {{ wood_break_trunk() }}

      IF(!hit_issue);

        DO(3);
        
          LOOK(,90,0.3);

          //{% "break_trunk.txt" %}
          {{ wood_break_trunk() }}

        UNTIL((%YPOS%==%#woodypos%) || (KEY_DELETE));

        &interact_="ON(%&hit_socket%) WRITE(pause: ok. thanks) AND WAIT UNTIL(paused)";

      ELSE;

        //LOG("break at 3/3");
        BREAK;

      ENDIF;

    ENDIF;

    //{% "../../modular/socket.interact.txt" %}
    {{ MODULAR.modular_socket_interact() }}

  NEXT;

{* endmacro *}

/*
  NOME: parts/wood/check_tools.txt
  DESCRIÇÃO: 
  HERE <- check_tools
*/
{* macro wood_check_tools() *}

  //=========================
  //=== CHECKS ITENS/TOOLS ==
  //========================= 
  UNSET(item_missing);
  PICK("6:0","sapling:0","6:1","sapling:1","6:2","sapling:2","6:3","sapling:3");//Try to pick sapling
  IFMATCHES(%ITEMIDDMG%,"6:0|sapling:0|6:1|sapling:1|6:2|sapling:2|6:3|sapling:3"); 
    PICK("351:15","dye:15");//Try to pick dye
    IFMATCHES(%ITEMIDDMG%,"351:15|dye:15");
      SET(&item_list,%&axe_list%);
      //{% "../../parts/common/pick_item.txt" %}
      {{ common_pick_item() }}
      IF(item_picked);
        &axe_id=%ITEMIDDMG%;
      ELSE;
        LOG("§e'§3Wood§e' §eNo axe");
        SET(item_missing);
      ENDIF;
    ELSE;
      LOG("§e'§3Wood§e' §eNo dye");
      SET(item_missing);
    ENDIF;
  ELSE;
    LOG("§e'§3Wood§e' §eNo sapling");
    SET(item_missing);
  ENDIF;

{* endmacro *}

/*
  NOME: parts/wood/scanner_above.txt
  DESCRIÇÃO: 
  HERE <- scanner_above
*/
{* macro wood_scanner_above() *}
  
  UNSET(#wood_above);
  UNSET(#obstruction_above);
  UNSET(#space_above);
  FOR(#i,0,11);
    GETIDREL(0,%#i%,0,&id_above,&data_above);
    IFMATCHES("%&id_above%","^0$|air");
      IF(!#obstruction_above);
        INC(#space_above);
      ENDIF;
    ELSE;
      IFMATCHES("%&id_above%","^17$|^log$|^6$|^sapling$");
        SET(#wood_above,%#i%);
        INC(#wood_above);
      ELSE;
        IF(!#obstruction_above);
          SET(#obstruction_above,%#i%);
          INC(#obstruction_above);
        ENDIF;
      ENDIF;
    ENDIF;
  NEXT;

{* endmacro *}

/*
  NOME: parts/wood/collects.txt
  DESCRIÇÃO: 
  HERE <- collects
*/
{* macro wood_collects() *}
  
  //=========================
  //=== IT BREAKS FRONT =====
  //========================= 

  &item_list=%&axe_list%;
  //{% "../../parts/common/pick_item.txt" %}
  {{ common_pick_item() }}

  FOR(#i,1,2);
    IF(#i==1);
      &interact_="ON(%&hit_socket%) NOTWRITE() AND WAIT UNTIL(paused)";
    ELSEIF(#i==2);
      &interact_="ON(%&hit_socket%) WRITE(resume:17|log,%&axe_list%,attack) AND WAIT UNTIL(resumed)";
    ENDIF;

    //=========================
    //=== IT CLEARS LEAVES =====
    //========================= 

    IFMATCHES(%HITID%,"18|leaves");
      //{% "clear_leaves.txt" %}
      {{ wood_clear_leaves() }}
    ENDIF;
    
    //{% "../../modular/socket.interact.txt" %}
    {{ MODULAR.modular_socket_interact() }}
  NEXT;

  //{% "../common/sensor.directions.txt" %}
  {{ common_sensor_directions() }}

  #dir=1;#nx=%#x%*%#dir%*1;#nz=%#z%*%#dir%*1;

  //---------------------------------
  //=== toggles axe position
  //---------------------------------
  UNSET(hit_issue);
  UNSET(walk_issue);
  FOR(#i,1,0);
    
    SET(&hit_message,"%%&hit_socket%%"); 

    IFMATCHES(%&hit_message%,"^missing_tool$");
      SET(hit_issue);
      BREAK;
    ELSE;

      #pitch=60*%#i%;
      LOOK(%#freeze_yaw%,%#pitch%,0.1);

      DO(50);

        IF(#i);
          GETIDREL(%#nx%,0,%#nz%,"&id_","&data_");
          SET(&sensor,"%&id_%"); 
        ELSE;
          GETIDREL(%#nx%,1,%#nz%,"&id_","&data_");
          SET(&sensor,"%&id_%");
        ENDIF;

        WAIT(50ms);
        //{% "../../modular/loop.txt" %}
        {{ MODULAR.modular_loop() }}

      UNTIL((&sensor!="17") && (&sensor!="log"));

    ENDIF;
    
    //{% "../../modular/loop.txt" %}
    {{ MODULAR.modular_loop() }}

  NEXT;

  IF(!hit_issue);

    //==============================================
    //=== MOVES FORWARD AND LOOKS TOWARDS UP =======
    //==============================================

    FOR(#i,1,4);
      IF(#i==1);
        &interact_="ON(%&walk_socket%) NOTWRITE() AND WAIT UNTIL(paused)";
      ELSEIF(#i==2);
        &interact_="ON(%&walk_socket%) WRITE(resume:FORWARD:SNEAK,1,-1) AND WAIT UNTIL(resumed)";
      ELSEIF(#i==3);
        LOOK(%#freeze_yaw%,270,0.7);
        &interact_="ON(%&walk_socket%) NOTWRITE() AND WAIT WHILE(resumed)";
      ELSEIF(#i==4);
        SET(&walk_message,%&interact_message_%);
        &interact_="ON(%&walk_socket%) WRITE(pause: ok. thanks) AND WAIT UNTIL(paused)";
      ENDIF;
      //{% "../../modular/socket.interact.txt" %}
      {{ MODULAR.modular_socket_interact() }}
    NEXT;

    IFMATCHES(%&walk_message%,"^ok$");

      //==============================================
      //=== WAIT TO BREAK THE WHOLE TRUNK ============
      //==============================================
      //{% "break_trunk.txt" %}
      {{ wood_break_trunk() }}

      IF(!hit_issue);
        //==============================================
        //=== SCANS SPACE ABOVE FOR LOGS OBSTRUCTIONS ==
        //==============================================
        //{% "scanner_above.txt" %}
        {{ wood_scanner_above() }}

        IF((#wood_above>7) && (#obstruction_above>#wood_above));

          RANDOM(#rphrase,5);
          IF(#rphrase==0);
            LOG("§e'§3Wood§e' OH CRAP!");
          ELSEIF(#rphrase==1);
            LOG("§e'§3Wood§e' That's not my first rodeo, boy!");
          ELSEIF(#rphrase==2);
            LOG("§e'§3Wood§e' OH Jesus! I hate that!");
          ELSEIF(#rphrase==3);
            LOG("§e'§3Wood§e' Again, again, again!");
          ELSEIF(#rphrase==4);
            LOG("§e'§3Wood§e' A W E S O M E. Now kill me");
          ELSEIF(#rphrase==5);
            LOG("§e'§3Wood§e' Damn wood!");
          ENDIF;

          //{% "build_support.txt" %}
          {{ wood_build_support() }}
        
        ENDIF;
      ENDIF;

      IF(!hit_issue);

        //=====================================
        //=== WALKS BACK ONE BLOCK ============
        //=====================================

        LOOK(%#freeze_yaw%,71,0.2); 

        SET(#xpos_stamp,%XPOS%);
        SET(#zpos_stamp,%ZPOS%);

        KEYUP(SNEAK);WAIT(1ms);
        DO(8);
          KEYDOWN(BACK);WAIT(100ms);
          KEYUP(BACK);WAIT(1ms);
        UNTIL((%XPOS%!=%#xpos_stamp%) || (%ZPOS%!=%#zpos_stamp%));

            
        //======================
        //=== ADJUST POSITION ==
        //======================

        //WAIT(4t);
        //CENTRALIZE();
        //WAIT(4t);

        KEYDOWN(SNEAK);WAIT(1ms);
        DO(8);
          IF((%XPOS%!=%HITX%) || (%ZPOS%!=%HITZ%));
            KEYDOWN(BACK);WAIT(1ms);
            KEYUP(BACK);WAIT(1ms);
          ENDIF;
          //{ "../../modular/loop.txt" }
          {{ MODULAR.modular_loop() }}
        UNTIL(((%XPOS%==%HITX%) && (%ZPOS%==%HITZ%)) || (break_));
        KEYUP(SNEAK);
        
      ELSE;

        LOG("§e'§3Wood§e' §8daemon_hit issue (%&hit_message%) [1]");
        SET(hit_issue);

      ENDIF;

        

    ELSE;

      LOG("§e'§3Wood§e' §8daemon_walk issue (%&walk_message%)");
      SET(walk_issue);

    ENDIF;

    

  ELSE;

    LOG("§e'§3Wood§e' §8daemon_hit issue (%&hit_message%) [2]");
    SET(hit_issue);

  ENDIF;

  &interact_="ON(%&hit_socket%) WRITE(pause: ok. thanks) AND WAIT UNTIL(paused)";
  //{% "../../modular/socket.interact.txt" %}
  {{ MODULAR.modular_socket_interact() }}

{* endmacro *}

/*
  NOME: parts/wood/fertilize.txt
  DESCRIÇÃO: 
  HERE <- fertilize
*/
{* macro wood_fertilize() *}
  
  //=========================
  //=== FERTILIZES SAPLING
  //========================= 
  IF((!break_) && (!pick_wood));
    IF((%HITX%!=%XPOS%) || (%HITZ%!=%ZPOS%));
      UNSET(#bmealcount);
      DO(5);
        PICK("351:15","dye:15"); //pegando o pó
        FOR(#fertlenha,0,3);
          KEY(USE); //aplicando o pó
          INC(#bmealcount);
          IFMATCHES(%HITID%,"17|log|18|leaves");
            SET(pick_wood);
            BREAK;
          ELSE;
            WAIT(77ms);
          ENDIF;
          //{% "../../modular/loop.txt" %}
          {{ MODULAR.modular_loop() }}
        NEXT;

        IF(pick_wood);

          BREAK;

        ENDIF;

          WAIT(50ms);

          IFMATCHES(%HITID%,"6|sapling");

            IF(#bmealcount>=20);

              LOG("§e'§3Wood§e' §6Obstruction detected. Trying to handle it");

              SET(pick_wood);

              BREAK;
              
            ENDIF;
            
          ELSE;

            IFMATCHES(%HITID%,"17|log|18|leaves");
              SET(pick_wood);
              BREAK;
            ELSE;
              //Maybe items are missing or this is not in the right place
              &next_="wood.centralize";
              SET(break_);
            ENDIF;

          ENDIF;

        ENDIF;

        //{% "../../modular/loop.txt" %}
        {{ MODULAR.modular_loop() }}

      LOOP;

    ELSE;

      &next_="wood.centralize";
      SET(break_);

    ENDIF;

  ENDIF;

{* endmacro *}

/*
  NOME: parts/wood/plants.txt
  DESCRIÇÃO:
  HERE <- plants
*/
{* macro wood_plants() *}

  WAIT(100ms);
  UNSET(pick_wood);
  IFMATCHES(%HITID%,"2|3|dirt|grass");
    PICK("6:0","sapling:0","6:1","sapling:1","6:2","sapling:2","6:3","sapling:3");//Try to pick sapling
    IFMATCHES(%ITEMIDDMG%,"6:0|sapling:0|6:1|sapling:1|6:2|sapling:2|6:3|sapling:3"); 
      KEY(USE); //plantando a muda
      WAIT(10ms);
    ELSE;
      SET(break_);
      &next_="wood.main_loop";
    ENDIF;
    
  ELSE;
    IFMATCHES(%HITID%,"17|log"); //se for madeira, comece a quebrar
      SET(pick_wood);
    ELSE;
      IFMATCHES(%HITID%,"^((?!6|sapling).)*$");
        LOG("§e'§3Wood§e' §6No way to plant the tree. Ending");
        &next_="wood.finalize(noway)";
        SET(break_);
      ENDIF;
    ENDIF;
  ENDIF;
  
{* endmacro *}

