/*
  NOME: parts/services/inventory_count.txt
  DESCRIÇÃO: 
*/
{* macro services_inventory_count() *}
  
  //SET(&item,"");
  //SET(&not_item,"");

  //{% "../common/open_inventory.txt" %}
  {{ common_open_inventory() }}
  UNSET(#item_quantity);
  UNSET(#ignored_item_quantity);
  IF(!&not_item);
    SET(&not_item,"^foobar$");
  ENDIF;
  FOR(#i,44,9);
    
    //{% "../common/keyendloop.txt" %}
    {{ common_keyendloop() }}

    //{% "../common/getslotitem.txt" %}
    {{ common_getslotitem() }}

    IFMATCHES(%&id%,%&item%);

      IFMATCHES(%&id%,%&not_item%);

        INC(#ignored_item_quantity,%#stack%);

      ELSE;

        IFMATCHES(%&id%,"^air$|^0$");
          INC(#item_quantity,1);
        ELSE;
          INC(#item_quantity,%#stack%);
        ENDIF;

      ENDIF;

    ENDIF;

  NEXT;

  #pack_quantity=%#item_quantity%/64;

  //{% "../common/close_inventory.txt" %}
  {{ common_close_inventory() }}

  LOG("§e'§3Inventory Count§e' §f%#item_quantity% §7itens found matching §f%&item%");

{* endmacro *}

/*
  NOME: reparador baseado no código do minerador
  DESCRIÇÃO: 
*/
{* macro services_cl_repair_tool(onchat='cl-syncpack') *}
    
  {* import 'Macrosoft.common.onchat' as ONCHAT *} 
  {* import 'Federal.@.shared' as SHARED *} 
  UNSET(repair_issue);
  
  {{ SHARED.tool.is_durability_ok(outvar='durable') }}
  
  IF(!durable);
  
    {{ ONCHAT.register(onchat) }}
    
    //SET(#current_durability,%DURABILITY%);
    SET(&repair_command_datetime,%DATETIME%);
    ECHO("/reparar");
    {{ CHAT.print('solicitação de reparação enviada ao servidor','info') }}
    UNSET(repaired);
    UNSET(not_vip);
  
    {* set timeout_repair = 250 *}
    UNSET(#timeout_repair);
    UNSET(&response);
    DO({{ timeout_repair }});
      INC(#timeout_repair);
      
      {{ CORTEX.read(CONSTANTS.servicepack['CL']['onchat']['pname'], "&response") }}
  
      IF(&response);
        IFMATCHES(%&response%,"^ok\:repair");
          SET(repaired);
        ELSE;
          {{ CHAT.print('O processo de reparação retornou um erro','error','%&response%') }}
        ENDIF;
        BREAK;
      ELSE;
      
        IF(&repair_command_datetime);
          {{ SECONDS.diff('%&repair_command_datetime%',outvar='#seconds_diff') }}
          IF(#seconds_diff>10); //10 segundos é o máximo para esperar reparação da ferramenta
            {{ CHAT.print('Passou-se 10 segundos e a macro não reparou','warning') }}
            {{ CHAT.print('Vou retornar mensagem de sucesso para manter o fluxo do programa','info') }}
            UNSET(&subject_repair_tool);//Esquece a ferramenta objeto
            {!! pause(trigger.task_name~':issue demorou mais de 10 segundos para reparar') !!}
            SET(repaired);//Demorou, mas a macro continuará tentando
            BREAK;
          ENDIF;
        ENDIF;
  
        IFMATCHES(%GUI%,"^GUICHEST");
          {{ CHAT.print('Você não é VIP, reparação cancelada!','info') }}
          {{ GUI.inventory(action='close',cortex=False) }}
          SET(not_vip);
          BREAK;
        ENDIF;
        
        WAIT(1t);
        
      ENDIF;
    
    UNTIL(repaired);
  
    //IF(DURABILITY>#current_durability);
    SET(repair_issue);
    IF(repaired);
      {{ CHAT.print('Beleza! Ferramenta reparada','success') }}
      UNSET(repair_issue);
    ELSEIF(not_vip);
      {{ CHAT.print('Não foi possível reparar a ferramenta 0','warning') }}
      {{ CHAT.print('indo trocar ferramenta...','info') }}
    ELSEIF(#timeout_repair<{{ timeout_repair }});
      UNSET(&subject_repair_tool);//Esquece a ferramenta objeto
      {{ CHAT.print('Não foi possível reparar a ferramenta 1','error') }}
    ELSE;
      UNSET(&subject_repair_tool);//Esquece a ferramenta objeto
      {{ CHAT.print('Não foi possível reparar a ferramenta 2','error','timeout') }}
    ENDIF;
      
    {{ ONCHAT.unregister(onchat) }}
  
  ENDIF;
  
{* endmacro *}

/*
  NOME: parts/services/cl/autorep.txt
  DESCRIÇÃO: 
*/
{* macro services_cl_autorep() *}
  
  //1 - Verifica a quantidade q de blocos de diamante no inventário
  //2 - Se houver itere no máximo q elementos n da hotbar, senão retorne 'rep_unavailable'
  //3 - Se o elemento n corresponder a %&autorep_id%, insira /reparar
  //4 - Depois de inserir /reparar, verifique se o item foi reparado, senão, retorne 'rep_unavailable'

  //SET(&autorep_id,"^diamond_pickaxe$|^278$");
  //SET(#autorep_durability,101);
  //SET(&autorep_block,"^57$|^diamond_block$")

  LOG("§e'§3CL /reparar§e' checking...");

  SET(&item,%&autorep_block%);
  UNSAFE(0);
    //{% "../inventory_count.txt" %}
    {{ services_inventory_count() }}
  ENDUNSAFE;

  //UNSET(#quant_hotbar_iter,%#item_quantity%);
  UNSET(#quant_hotbar_iter);
  UNSET(repair_issue);

  IF(!#autorep_durability);
    SET(#autorep_durability,105);
  ENDIF;

  IF(#item_quantity);

    //FOR(#i,1,9);
        
      SLOT(%#i%);//Go to slot

      WAIT(50ms);

      //IFMATCHES(%ITEM%,%&autorep_id%); //Check slots contains target

        //IF(%DURABILITY%<=#autorep_durability);//Checks durability

          SET(#last_durability,%DURABILITY%);

          ECHO("/reparar -a"); 

          UNSET(#j);
          DO(100);

            INC(#j);
            IFMATCHES(%#j%,"10|20|30|40|50|60|70|80|90");
              LOG("§a§lAguardando aumento da durabilidade §f%#j%/100 §8abrindo §8baú §8para §8evitar §8bug §8do §8servidor. §8Obrigado §3@ninjacinzabr §8por §8identificar §8e §8relatar §8o §8problema");
              //Sugestão de @ninjacinzabr S2
              IFMATCHES(%HITID%,"^146$|^54$|^trapped_chest$|^chest$")
                //{% "../../common/open_chest.txt" %}
                {{ common_open_chest() }}
                WAIT(10t);
                //{% "../../common/close_inventory.txt" %}
                {{ common_close_inventory() }}
              ENDIF;
            ENDIF;
            WAIT(10t);

            IFMATCHES(%GUI%,%GUICHEST%);
              LOG("§a§lVocê não é VIP. Cancelando §7§l/reparar");
              //{% "../../common/close_inventory.txt" %}
              {{ common_close_inventory() }}
              SET(repair_issue);
              BREAK;
            ENDIF;

            SET(#current_durability,%DURABILITY%);

            //{% "../../../modular/loop.txt" %}
            {{ MODULAR.modular_loop() }}

          UNTIL(#current_durability>#last_durability);

          IF(%DURABILITY%>#last_durability);
            LOG("§e'§3CL /reparar§e' §eOK");
          ELSE;
            LOG("§e'§3CL /reparar§e' §4ISSUE");
            SET(repair_issue);
            BREAK;
          ENDIF;

          //IF(#i>=#quant_hotbar_iter);
          //  BREAK;
          //ENDIF;

        //ENDIF;

      //ENDIF;

    //NEXT;

  ELSE;

    SET(repair_issue);
    LOG("§e'§3CL /reparar§e' §4no block of diamond found");

  ENDIF;
  
{* endmacro *}


/*
  NOME: parts/services/picker.txt
  DESCRIÇÃO: 
    # Serviço PICKER
     Este serviço pretende ser o definitivo para trazer um item do inventário para a hotbar.
     Para que um item seja selecionado este precisa ter durabilidade maior que 9 ou menor que 1
    
    ## Inputs
     * a=>b (a:regex para a validação de id:data, b:posição destino da hotbar [1-9])
    
    ## Outputs
     * ok
     * not_available:id
     * low_durability:id
    
    ## Algoritmo
     1. O item está na posição da hotbar?
       * SIM: Mova o cursor para a posição escolhida e retorne 'ok'
       * NÃO: Comece o processo de busca
         * Abra o inventário
         * Iniciando do início da hotbar até o topo itere o slot S
           * O slot S corresponde ao item solicitado
             * SIM: Mova o item para a posição destino trocando os itens entre os slots e retone 'ok'
             * NÃO: Próxima iteração
         * Como o item não foi encontrado retone 'not_found'
*/
{* macro services_picker(inputvar='&express',outvar='&ibm_return_') *}
  
  UNSET(&parts[]);
  //-----------------------------------
  // Parses input
  //-----------------------------------
  MATCH(%{{ inputvar }}%,"([^=]+)(?:=>([0-9]+))?",&parts[]);
  
  SET(&regex_item,%&parts[1]%);
  MATCH(%&parts[2]%,"([0-9-]+)?",{#hotpos});
  //LOG("§e'§3Picker§e' §8regex_item:§7%&regex_item% §8hotpos:§7%#hotpos%");
  
  IF(&regex_item);
  
    //-----------------------------------
    // Set 1 to hotbar target position if it was not informed
    //-----------------------------------
    IF((#hotpos<=0) || ((#hotpos>=10)));
  
      SET(#hotpos,1);
  
    ENDIF;
  
    //-----------------------------------
    // It checks hotbar
    //-----------------------------------
  
    SET(not_available);
    UNSET(low_durability);
    SLOT(%#hotpos%);
  
    IFMATCHES("%ITEM%",%&regex_item%);
      IF(%STACKSIZE%>0);
        #durability_left=((10000*%DURABILITY%)/(100*%ITEMDAMAGE%));
        IF((DURABILITY<=0)||(#durability_left>10));
          UNSET(not_available);
          LOG("§e'§3Picker§e' §a§lOK§r§8 §7%ITEM% §aalready placed");
        ELSE;
          SET(low_durability);
          //LOG("§e'§3Picker§e' Some item skipped. §8Low durability");
        ENDIF;
      ENDIF;
    ENDIF;
  
    IF(not_available);
  
      //{% "../common/open_inventory.txt" %}
      {{ common_open_inventory() }}
  
      FOR(#i,44,9);
  
        //{% "../common/keyendloop.txt" %}
        {{ common_keyendloop() }}
  
        //{% "../common/getslotitem.txt" %}
        {{ common_getslotitem() }}
  
        SET(#invhotpos,%#hotpos%);
        INC(#invhotpos,35);
  
        IF(#i!=#invhotpos);
  
          IFMATCHES("%&id%",%&regex_item%);
  
            //WAIT(50ms);
            //SLOTCLICK(%#i%,left);WAIT(50ms);//Pick item
            //SLOTCLICK(%#invhotpos%,left,true);WAIT(50ms);//Clear target position
            //SLOTCLICK(%#invhotpos%,left);WAIT(50ms);//Place item
  
            WAIT(500ms);
            SLOTCLICK(%#i%,left);WAIT(750ms);//Pick item
            SLOTCLICK(%#invhotpos%,left);WAIT(750ms);//Clear target position
            SLOTCLICK(%#i%,left);WAIT(750ms);//Place item
            SLOTCLICK(-999);
  
            SLOT(%#hotpos%);
  
            IF(%STACKSIZE%>0);
  
              #durability_left=((10000*%DURABILITY%)/(100*%ITEMDAMAGE%));
              IF((DURABILITY<=0)||(#durability_left>10));
                UNSET(not_available);
                SET({{ outvar }},"ok");
                LOG("§e'§3Picker§e' §a§lOK§r§8 §7%ITEM% ==> inventory(%#hotpos%)");
                BREAK;
              ELSE;
                SET(low_durability);
                //LOG("§e'§3Picker§e' Some item skipped. §8Low durability");
              ENDIF;
            ENDIF;
            
          ENDIF;
          
        ENDIF;
  
      NEXT;
  
      //{% "../common/close_inventory.txt" %}
      {{ common_close_inventory() }}
  
      IF(not_available);
        IF(low_durability);
          LOG("§e'§3Picker§e' §4§lLOW DURABILITY§r§8 §7%ITEM% ==> inventory(%#hotpos%)");
          SET({{ outvar }},"low_durability:%&regex_item%");
        ELSE;
          LOG("§e'§3Picker§e' §4No matches found for §7%&regex_item%");
          SET({{ outvar }},"not_available:%&regex_item%");
        ENDIF;
      ENDIF;
  
    ELSE;
  
      SET({{ outvar }},"ok");
  
    ENDIF;
  
  ELSE;
  
    SET({{ outvar }},"not_available:%&regex_item%");
  
  ENDIF;

{* endmacro *}

/*
  NOME: parts/services/chest_replace_damaged.txt
  DESCRIÇÃO: 
*/
{* macro services_chest_replace_damaged() *}
  
  //SET(&items_to_exchange,".+_pickaxe");
  SET(chest_not_available);

  IFMATCHES(%HITID%,"^146$|^54$|^trapped_chest$|^chest$")
    //{% "../common/open_chest.txt" %}
    {{ common_open_chest() }}
    IFMATCHES(%GUI%,CHEST);
      UNSET(chest_not_available);
      //selectiona uma posição do inventário
      //se o item não estiver na hotbar coloque-o lá trocando com um slot aleatório da hotbar
      //se o item tiver baixa durabilidade, troque com algum do baú
      //recoloque o item em sua posição original, se for o caso

      IF(!&items_to_exchange);
        SET(&items_to_exchange,"^271$|^275$|^258$|^279$|^286$|^.+_axe$|^270$|^274$|^257$|^278$|^285$|^.+_pickaxe$|^269$|^273$|^256$|^277$|^284$|^.+_shovel$|^268$|^272$|^267$|^276$|^283$|^.+_sword$|^359$|^shears$|^261$|^bow$|^290$|^291$|^292$|^293$|^294$|^.+_hoe$|^346$|^fishing_rod$");
      ENDIF;

      UNSET(exchanged);

      FOR(#j,54,89);

        //{% "../common/keyendloop.txt" %}
        {{ common_keyendloop() }}
        
        //GetSlotItem crossversion
        UNSET(&idj);
        GETSLOTITEM(%#j%,&idj,#s,&d);
        IF(!&idj);
          GETSLOTITEM(%#j%,#idj,#s,#d);
          MATCH("%#idj%","([0-9]+)",{&idj});
        ENDIF;

        IFMATCHES(%&idj%,%&items_to_exchange%);

          IF(#j<=80);
            //Sort a slot target
            DO;
              RANDOM(#slot,1,9);
              #invslot=80+%#slot%;

              //{% "../common/keyendloop.txt" %}
              {{ common_keyendloop() }}

            UNTIL(#invslot!=%#j%);

            //Put the item on hotbar
            WAIT(77ms);
            SLOTCLICK(%#j%,left);
            WAIT(77ms);
            SLOTCLICK(%#invslot%,left);
            WAIT(77ms);
            SLOTCLICK(%#j%,left);
            WAIT(77ms);
          ELSE;
            #slot=%#j%-80;
            #invslot=%#j%;
          ENDIF;

          SLOT(%#slot%);

          //Exchange itens on chest
          IF(%DURABILITY%<=101);
            FOR(#i,0,53);

              //{% "../common/keyendloop.txt" %}
              {{ common_keyendloop() }}

              IF(#i!=#j);

                //GetSlotItem crossversion
                UNSET(&idi);
                GETSLOTITEM(%#i%,&idi,#s,&d);
                IF(!&idi);
                  GETSLOTITEM(%#i%,#idi,#s,#d);
                  MATCH("%#idi%","([0-9]+)",{&idi});
                ENDIF;

                IFMATCHES(%&idi%,"^%&idj%$");

                  //Exchange item with chest
                  WAIT(77ms);

                  DO(20);
                    SLOTCLICK(%#i%,left);
                    //SET(&custom_i,"#i");
                    //{% "../common/getslotitemcustomvar.txt" %}
                    {{ common_getslotitem(countvar='#i') }}
                    WAIT(250ms);
                  UNTIL(#stack==0);

                  SLOTCLICK(%#invslot%,left);
                  WAIT(250ms);

                  DO(20);
                    SLOTCLICK(%#i%,left);
                    //SET(&custom_i,"#i");
                    //{% "../common/getslotitemcustomvar.txt" %}
                    {{ common_getslotitem(countvar='#i') }}
                    WAIT(250ms);
                  UNTIL(#stack>0);

                  //Gives the item back to the position if it has not enough durability
                  SLOT(%#slot%);
                  IF(%DURABILITY%<=101);

                    DO(20);
                      SLOTCLICK(%#invslot%,left);
                      //SET(&custom_i,"#invslot");
                      //{% "../common/getslotitemcustomvar.txt" %}
                      {{ common_getslotitem(countvar='#invslot') }}
                      WAIT(250ms);
                    UNTIL(#stack==0);

                    
                    SLOTCLICK(%#i%,left);
                    WAIT(250ms);

                    DO(20);
                      SLOTCLICK(%#invslot%,left);
                      //SET(&custom_i,"#invslot");
                      //{% "../common/getslotitemcustomvar.txt" %}
                      {{ common_getslotitem(countvar='#invslot') }}
                      WAIT(250ms);
                    UNTIL(#stack>0);

                  ELSE;
                    LOG("§e'§3Chest Replacer§e' §a§lOK§r§8 §7%ITEM% §aexchanged");
                    SET(exchanged);
                    BREAK;
                  ENDIF;

                ENDIF;

              ENDIF;

            NEXT;
          ENDIF;

          IF(#j<=80);
            //Give the item back to the origin slot
            WAIT(77ms);
            

            DO(20);
              SLOTCLICK(%#invslot%,left);
              //SET(&custom_i,"#invslot");
              //{% "../common/getslotitemcustomvar.txt" %}
              {{ common_getslotitem(countvar='#invslot') }}
              WAIT(250ms);
            UNTIL(#stack==0);

            SLOTCLICK(%#j%,left);
            WAIT(250ms);
            
            DO(20);
              SLOTCLICK(%#invslot%,left);
              //SET(&custom_i,"#invslot");
              //{% "../common/getslotitemcustomvar.txt" %}
              {{ common_getslotitem(countvar='#invslot') }}
              WAIT(250ms);
            UNTIL(#stack>0);

          ENDIF;


        ENDIF;
        
      NEXT;

      //{% "../common/close_inventory.txt" %}
      {{ common_close_inventory() }}

    ELSE;

      LOG("§e'§3Chest Replacer§e' chest not available");

    ENDIF;

  ELSE;

    LOG("§e'§3Chest Replacer§e' chest not found");

  ENDIF;
  
{* endmacro *}

/*
  NOME: parts/services/inventory_split_item.txt
  DESCRIÇÃO: 
*/
{* macro services_inventory_split_item() *}
  

  //{% "../common/open_inventory.txt" %}
  {{ common_open_inventory() }}
  
  FOR(#i,44,9);
  
    //{% "../common/keyendloop.txt" %}
    {{ common_keyendloop() }}
  
    //{% "../common/getslotitem.txt" %}
    {{ common_getslotitem() }}
    
    IFMATCHES("%&id%","%&item%");
      WAIT(250ms);
      SLOTCLICK(%#i%,left);WAIT(250ms);
      SLOTCLICK(1,left);WAIT(250ms);
      SLOTCLICK(0,left,true);WAIT(250ms);
    ENDIF;
  
    //CHeck if there's space
    SET(full);
    FOR(#j,44,9);
  
      //{% "../common/keyendloop.txt" %}
      {{ common_keyendloop() }}
  
      UNSET(&id);
      GETSLOTITEM(%#j%,&id,#stack,&damage);
      IF(!&id);
        GETSLOTITEM(%#j%,#id,#stack,#damage);
        MATCH("%#id%:%#damage%","([0-9]+):([0-9]+)",{&id,&damage});
      ENDIF;
  
      IFMATCHES("%&id%","^0$|^air$");
        UNSET(full);
        BREAK;
      ENDIF;
  
    NEXT;
  
    IF(full);
      LOG("§8§lInventory full!");
      BREAK;
    ENDIF;
  
  NEXT;
  
  //{% "../common/close_inventory.txt" %}
  {{ common_close_inventory() }}


  
{* endmacro *}

