/* OPERAÇÃO DE VERIFICAR HERE <- op_mover */
/* TENTA MOVER TODOS OS ITENS DA REGEX_ID, CASO NAO TENHA SUCESSO, RETORNA OUTVAR=TRUE */
{* macro op_mover(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	{* set rand = nid() *}
	ifmatches("{{ id }}","{{ regex_id }}");
		//LOG("entrei: {{ regex_id }} matches with {{ id }}");
		set(#stack{{ rand }},{{ stacksize }})
		slotclick({{ slot }},l,true);
		getslotitem({{ slot }},#i{{ rand }},#s{{ rand }});
		if(#s{{ rand }}!=0);
			set({{ outvar }});//Aki marca-se erro e quebra-se o loop
		endif;
	endif;
	
{* endmacro *}



/* OPERAÇÃO DE VERIFICAR HERE <- op_apanhar */
/*
	GOTO -> op_descarregar
	TENTA MOVER A QUANTIDADE ESPERADA DE SLOT DE ITENS, E RETORNA A QUANTIDADE DE SLOTS MOVIDOS
	RETORNA QUANTIDADE NEGATIVA SE O ÚLTIMO SLOT VERIFICADO NÃO PUDER TER SIDO MOVIDO COMPLETAMENTE
*/
{* macro op_apanhar(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	{* set rand = nid() *}
	//LOG("slot_inicio: {{ slot_inicio }} slot_fim: {{ slot_fim }}");
	IF({{ slot }}=={{ slot_inicio }});
		UNSET(#quant{{ rand }});//Reseta a variável que acumula a quantidade
	ENDIF;
	UNSET({{ errorvar }});//Adicionei isso em 30 de agosto de 2020. Provavelmente, antes disso, estava causando os bugs
	IFMATCHES("{{ id }}","{{ regex_id }}");
		SET(#stack{{ rand }},{{ stacksize }});
		SLOTCLICK({{ slot }},l,true);
		{{ run_delay(delay=delay) }}
		GETSLOTITEM({{ slot }},#i{{ rand }},#newstacksize{{ rand }});
		IF(#stack{{ rand }}>#newstacksize{{ rand }});//Só incrementa a quantidade de movidos, se o número atual é menor que o anterior
			INC(#quant{{ rand }},1);
		ENDIF;
		SET({{ outvar }},%#quant{{ rand }}%);
		IF(#newstacksize{{ rand }}!=0);//Indica que após tentar mover, o slot continua ocupado
			SET({{ errorvar }});
			BREAK;
		ENDIF;
		IF(({{ quantidade }}>0)&&(#quant{{ rand }}>={{ quantidade }}));
			BREAK;
		ENDIF;
	endif;
	
{* endmacro *}

{* macro op_teste(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	LOG("§7slot:§c{{ slot }} §7id:§c{{ id }} §7data:§c{{ data }} §7regex_id:§c{{ regex_id }} §7outvar:§c{{ outvar }} §7errorvar:§c{{ errorvar }} §7slot_target:§c{{ slot_target }}");
{* endmacro *}


//HERE <- op_hotswap
{* macro op_hotswap(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	
	{* set r = nid() *}
	{* import 'Federal.INTEL.insights' as INSIGHTS *}
	{* import 'Federal.@.shared' as SHARED *}
	
	IFMATCHES("{{ id }}","{{ regex_id }}");
		SET({{ outvar }},{{ slot }});
		HOTSWAP({{ slot }},{{ slot_target }});
		BREAK;
	ENDIF;
{* endmacro *}

/* OPERAÇÃO DE VERIFICAR HERE <- op_movimentar */
{* macro op_movimentar(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	ifmatches("{{ id }}","{{ regex_id }}");
		{* if slot_target == None *}
			slotclick({{ slot }},l,true);
		{* else *}
			slotclick({{ slot }});
			slotclick({{ slot_target }});
			break;
		{* endif *}
	endif;
	
{* endmacro *}

