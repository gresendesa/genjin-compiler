/* OPERAÇÃO DE CRAFTAR HERE <- op_craftar */
{* macro op_craftar(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	
	ifmatches("{{ id }}","{{ regex_id }}");
		SLOTCLICK({{ slot }});
		{{ run_delay(delay=delay) }}
		SLOTCLICK({{ slot_target }});
		{{ run_delay(delay=delay) }}
		SET({{ outvar }}); //Indica que o item foi encontrado e movido
		BREAK;
	endif;
	
{* endmacro *}


/* OPERAÇÃO DE DESCARREGAR O INV NO BAÚ
	'outvar' representa erro se estiver como true
	1. (se stacksize > 1) joga o item, da posição P, tipo T pra o baú
	(se stacksize <= 1) volte para 1.
	1.a se a posição P ficar vazia, vá para a 2.
	1.b se a posição P ainda permanecer com itens, significa baú cheio
	portanto pare e defina erro
	2. procura a primeira posição D com o item tipo T no baú (com stacksize > 1)
	3. após encontrá-lo (no baú), clica com o botão esquerdo no item
	4. move o item para o inventário clicando com o botão direito na posição P
	5. devolve o item para o baú clicando com o botão esquerdo na posição D
*/
{* macro op_descarregar_bau_duplo(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	
	{* set rand = nid() *}
	
	IF({{ stacksize }}>1)
		IFMATCHES("{{ id }}","{{ regex_id }}");//Se verdadeiro é do tipo T
			GETSLOTITEM({{ slot }},#id{{ rand }});//Guardo o id do item antes de movê-lo
			SLOTCLICK({{ slot }},l,true);//1.
			GETSLOTITEM({{ slot }},#id_resultado{{ rand }});//verifico o que sobrou no slot
			IF(#id_resultado{{ rand }}==0);//Está vazio, então prossiga
				SET(#posicao_d{{ rand }},-1);
				{{ itera_gui(operação=op_buscar_pilha,slot_inicio=0, slot_fim=53, regex_id='^%#id'~rand~'%$', outvar="#posicao_d"~rand) }}
				SLOTCLICK(%#posicao_d{{ rand }}%,l,false);
				SLOTCLICK({{ slot }},r,false);
				SLOTCLICK(%#posicao_d{{ rand }}%,l,false);
			ELSE;
				SET({{ outvar }});//Marca erro
				BREAK;
			ENDIF;
		ENDIF;
	ENDIF;
	
{* endmacro *}


/*
	DESCARREGA OS ITENS
	RETORNA EM OUTVAR A QUANTIDADE DE ITENS MOVIDOS
	RETORNA EM ERRORVAR TRUE CASO O ÚLTIMO SLOT NÃO PUDER TER SIDO MOVIDO COMPLETAMENTE
	HERE <- op_descarregar
	GOTO -> op_apanhar
*/
{* macro op_descarregar(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	
	{* set rand = nid() *}
	IF({{ slot }}=={{ slot_inicio }});
		UNSET(#quant{{ rand }});//Reseta a variável que acumula a quantidade
	ENDIF;
	
	UNSET({{ errorvar }});//Adicionei isso em 30 de agosto de 2020. Provavelmente, antes disso, estava causando os bugs
	
	IF({{ stacksize }}>1)
		IFMATCHES("{{ id }}","{{ regex_id }}");//Se verdadeiro é do tipo T
			GETSLOTITEM({{ slot }},#id{{ rand }},#stack{{ rand }});//Guardo o id do item antes de movê-lo
			SLOTCLICK({{ slot }},l,true);//1.
			{{ run_delay(delay=delay) }}
			GETSLOTITEM({{ slot }},#i{{ rand }},#newstack{{ rand }});//verifico o que sobrou no slot
			
			IF(#stack{{ rand }}>#newstack{{ rand }});//Só incrementa a quantidade de movidos, se o número atual é menor que o anterior
				INC(#quant{{ rand }},1);
			ENDIF;
			SET({{ outvar }},%#quant{{ rand }}%);
			IF(#newstack{{ rand }}!=0);//Indica que após tentar mover, o slot continua ocupado
				SET({{ errorvar }});
				BREAK;
			ENDIF;
			
			SET(#posicao_d{{ rand }},-1);
			{{ itera_gui(operação=op_buscar_pilha, slot_inicio=0, slot_fim=53, regex_id='^%#id'~rand~'%$', outvar="#posicao_d"~rand) }}
			SLOTCLICK(%#posicao_d{{ rand }}%,l,false);
			{{ run_delay(delay=delay) }}
			SLOTCLICK({{ slot }},r,false);
			{{ run_delay(delay=delay) }}
			SLOTCLICK(%#posicao_d{{ rand }}%,l,false);
			{{ run_delay(delay=delay) }}
			
			IF(({{ quantidade }}>0)&&(#quant{{ rand }}>={{ quantidade }}));
				BREAK;
			ENDIF;
			
		ENDIF;
	ENDIF;
	
{* endmacro *}


{* macro gera_regex(ids=[], data_padrão=None) -*}
	
	{* if data_padrão!= None -*}
		
		{{ '^'+ids|join(':'+data_padrão+'$|^')+':'+data_padrão+'$' }}
		
	{*- else -*}
		
		{{ '^'+ids|join('$|^')+'$' }}
		
	{*- endif *}
	
	
{*- endmacro *}

