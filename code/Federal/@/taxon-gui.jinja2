/*
	Abre qualquer tipo de GUI
*/
{* macro abre_gui(tipo='INVENTORY') *}
	wait(5t)
	DO;
		{* if tipo == 'GUICHEST' *}
			KEY(USE);
		{* else *}
			GUI("{{ tipo }}");
		{* endif *}
		wait(5t);
	UNTIL(GUI="{{ tipo }}");
{* endmacro *}

{* macro run_delay(delay) *}
	
	{* if delay != None and delay != 0 *}
		WAIT({{ delay }}t);
	{* endif *}
	
{* endmacro *}

/*
	OPERA GENERICAMENTE QUALQUER GUI HERE <- itera_gui
	Esta macro cria um loop que itera uma GUI de 'slot_inicio' a 'slot_fim'
	Essa macro requer uma macro 'operação' que realize um trabalho a cada loop
	
*/
{* macro itera_gui(operação, regex_id=None, outvar=None, errorvar=None, slot_inicio=9, slot_fim=44, resetar_outvar=True, delay=None, slot_target=None, quantidade=None) *}
	
	{* if outvar != None and resetar_outvar *}
		UNSET({{ outvar }});
		//HERE <- jeff
	{* endif *}
	
	{* if errorvar != None *}
		UNSET({{ errorvar }});
		//HERE <- jeff
	{* endif *}
	
	{* set rand = nid() *}
	
	FOR(#slot{{ rand }},{{ slot_inicio }},{{ slot_fim }});
		
		{* if this.protocol == 'CTRL' *}
			{* import 'Macrosoft.cortex.common' as CORTEX *}
			{{ CORTEX.loop() }}
		{* endif *}
		
		IFMATCHES("%ITEM%","^[0-9]+$");//1.5.2
			GETSLOTITEM(%#slot{{ rand }}%,#id{{ rand }},#stacksizevar{{ rand }},#datavar{{ rand }});
			MATCH("%#id{{ rand }}%:%#datavar{{ rand }}%","([0-9]+):([0-9]+)",{{ '{&id'~rand~',&datavar'~rand~'}' }});
		ELSE;//1,8
			GETSLOTITEM(%#slot{{ rand }}%,&id{{ rand }},#stacksizevar{{ rand }},&datavar{{ rand }});
		ENDIF;
		
		{{ operação(slot='%#slot'~rand~'%', id='%&id'~rand~'%', stacksize='%#stacksizevar'~rand~'%', data='%&datavar'~rand~'%', regex_id=regex_id, outvar=outvar, errorvar=errorvar, slot_target=slot_target, quantidade=quantidade, slot_inicio=slot_inicio, slot_fim=slot_fim, delay=delay) }}
		
	NEXT;
	
{* endmacro *}


