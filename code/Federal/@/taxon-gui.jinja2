/* OPERAÇÃO DE CONTAR POR UNIDADE HERE <- op_craftar_unidade */
{* macro op_craftar_unidade(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	
	ifmatches("{{ id }}","{{ regex_id }}");
