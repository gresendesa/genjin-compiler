{* macro op_contar_pilha(slot, id, stacksize, data, regex_id, outvar, errorvar, slot_target, quantidade, slot_inicio, slot_fim, delay) *}
	
	{* set rand = nid() *}
	
	GETSLOTITEM({{ slot }},#id_var{{ rand }});
	GETITEMINFO(%#id_var{{ rand }}%,&namevar{{ rand }},#maxstacksize{{ rand }});
	ifmatches("{{ id }}","{{ regex_id }}");
		IF(#maxstacksize{{ rand }}=={{ stacksize }});
			inc({{ outvar }},1);
		ENDIF;
	endif;
	
{* endmacro *}

