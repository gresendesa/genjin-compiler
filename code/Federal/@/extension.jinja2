{* set escaped_csid = this.csid|replace("-","_")|replace(".","_")|lower() *}

/*
  DESCRIÇÃO: Isso pega o valor de uma variável e joga em outra
*/
{* macro map_variable(var,outvar) *}
  {* if '%' in var *}
    {* set rid = nid() *}
    SET(&variable_name{{ rid }},"{{ var }}");
    SET({{ outvar }},%%&variable_name{{ rid }}%%);
  {* else *}
    SET({{ outvar }},"%{{ var }}%");
  {* endif *}
{* endmacro *}

/*
  DESCRIÇÃO: Isso define o valor de uma variável com o valor definido em value
*/
{* macro set_variable(var,value=None) *}
  {* if '%' in var *}
    {* set rid = nid() *}
    SET(&variable_name{{ rid }},"{{ var }}");
    {* if value != None *}
      SET(%&variable_name{{ rid }}%,"{{ value }}");
    {* else *}
      SET(%&variable_name{{ rid }}%);
    {* endif *}
  {* else *}
    {* if value != None *}
      SET({{ var }},"{{ value }}");
    {* else *}
      SET({{ var }});
    {* endif *}
  {* endif *}
    
{* endmacro *}

/*
  DESCRIÇÃO: Isso apaga a variável
*/
{* macro unset_variable(var) *}
  {* if '%' in var *}
    {* set rid = nid() *}
    SET(&variable_name{{ rid }},"{{ var }}");
    UNSET(%&variable_name{{ rid }}%);
  {* else *}
    UNSET({{ var }});
  {* endif *}
{* endmacro *}

/*
  
  Cria uma variável padronizada

*/
{* macro context_variable(extension, name, prefix='') -*}

  {{ prefix~'ext_'~escaped_csid~'_'~name~'_'~extension }}
    
{*- endmacro *}
/*
  NOME: registrar extensão
  DESCRIÇÃO: esta macro registra a extensão no contexto.
  Ela incia a extensão em modo pausado e já requisita 
  Lembre-se que 'name' deve receber caracteres alfanuméricos e
  underlines somente.
  suas informações para registrá-los no contexto. 
  Adicionamente atribui a 'outvar' a string que contém
  suas informações.
  Isso permite que ela seja chamada ao longo de um projeto.
  Ela só recebe o nome da extensão como parâmetro
  TODO: Em name usar somente caracteres alfatnuméricos e underline
*/
{* macro client_register(id, name='extension', outvar='&info'~nid(), success_outvar='success'~nid(), timeout=120, debug=False, arguments=[]) *}
	
	{* set rid = nid() *}
	{{ map_variable(context_variable(extension=name, name='enabled'),'enabled'~rid) }}
	IF(!enabled{{ rid }});
	  
	  {* if debug *}
      {{ CHAT.print('ok, registering!','info','debug-client-register') }}
    {* endif *}
	
  	{{ SERVICEPACK.load(id=id, pname=name, success_outvar=success_outvar, timeout=timeout) }}
  	
  	{* if debug *}
      {{ CHAT.print('loaded: %'~success_outvar~'%','info','debug-client-register') }}
    {* endif *}
  	
  	IF({{ success_outvar }});

  	  {{ SERVICEPACK.play(pname=name, task='info', outvar=outvar, timeout=120, arguments=arguments) }}
  	  
  	  UNSET({{ success_outvar }});
  	  IF({{ outvar }});
  	    SET({{ success_outvar }});
  	  ENDIF;
  	  
  	  {!! set_variable('&extension_'~escaped_csid~'_'~name~'_info','%'~outvar~'%') !!}
  	  {!! set_variable('extension_'~escaped_csid~'_'~name~'_enabled','%'~success_outvar~'%') !!}
  	  
  	  {{ set_variable(context_variable(extension=name, name='info', prefix='&'),'%'~outvar~'%') }}
  	  {{ set_variable(context_variable(extension=name, name='enabled'),'%'~success_outvar~'%') }}
  	  
  	  {* if debug *}
        {{ CHAT.print('info: %'~outvar~'%','info','debug-client-register') }}
      {* endif *}
  	  
  	  /*SET({{ '&extension_'~escaped_csid~'_'~name~'_info' }},%{{ outvar }}%);
  	  SET({{ 'extension_'~escaped_csid~'_'~name~'_enabled' }},%{{ success_outvar }}%);*/
  	  
  	ENDIF;
  ENDIF;
	
{* endmacro *}


/*
  NOME: desabilita contexto
  DESCRIÇÃO: esta macro desabilita o contexto.
  Ela envia um sinal para que a extensão em execução
  seja finalizada. Além disso reseta todas as varáveis
  de contexto.
  TODO: Em name usar somente caracteres alfatnuméricos e underline
*/
{* macro client_unregister(name='extension', force=True) *}
	{* if not force *}
	  {* set rid = nid() *}

	  {{ map_variable(context_variable(extension=name, name='enabled'),'enabled'~rid) }}
	  
	  IF(!enabled{{ rid }});
	  /*IF({{ 'extension_'~escaped_csid~'_'~name~'_enabled' }});*/
  {* endif *}
	
	  {{ SERVICEPACK.stop(pname=name) }}
	  /*UNSET({{ 'extension_'~escaped_csid~'_'~name~'_enabled' }});*/
	  {{ unset_variable(context_variable(extension=name, name='enabled')) }}
	{* if not force *}
	  ENDIF;
  {* endif *}

{* endmacro *}

/*
  NOME: menu de informações par ao cliente
  DESCRIÇÃO: Isso lê a informação cedida pela extensão e gera um menu
  que detalha as funções daquela extensão
*/
{* macro client_info_menu(info) *}
  
  {* set rid = nid() *}

  MATCH("{{ info }}","([^,]+),(.*)",{{ '{&owner'~rid~',&dictcopy'~rid~'}' }});

  UNSET(&services{{ rid }}[]);
  UNSET(&descriptions{{ rid }}[]);
  UNSET(&returns{{ rid }}[]);
  
	DO;
		IFMATCHES("%&dictcopy{{ rid }}%","^{{ DICT.left_item_border }}[^{{ DICT.right_item_border }}]+{{ DICT.right_item_border }}→{{ DICT.left_item_border }}[^{{ DICT.right_item_border }}]*{{ DICT.right_item_border }}.*",&dictvalueaux{{ rid }});
			UNSET(&dictgroups{{ rid }}[]);
			MATCH(%&dictvalueaux{{ rid }}%,"^{{ DICT.left_item_border }}([^{{ DICT.right_item_border }}]+){{ DICT.right_item_border }}→{{ DICT.left_item_border }}([^{{ DICT.right_item_border }}]*){{ DICT.right_item_border }}(.*)",&dictgroups{{ rid }}[]);
			//LOG("§7%&dictgroups{{ rid }}[1]% §8→ §f%&dictgroups{{ rid }}[2]%");
			IF(&dictgroups{{ rid }}[2]);
  			MATCH("%&dictgroups{{ rid }}[2]%","(.*){{ alias_separator }}(.*)",{{ '{&alias'~rid~',&description'~rid~'}' }});
  			PUT(&services{{ rid }}[],"§b%&alias{{ rid }}% §8%&dictgroups{{ rid }}[1]%");
  			PUT(&descriptions{{ rid }}[],"%&description{{ rid }}%");
  		ENDIF;
			SET(&dictcopy{{ rid }},%&dictgroups{{ rid }}[3]%)
		ELSE;
			BREAK;
		ENDIF;
	LOOP;
	
  UNSET(&string_list_items{{ rid }});
  FOREACH(&services{{ rid }},&item{{ rid }});
    IF(&string_list_items{{ rid }});
      SET(&string_list_items{{ rid }},"%&string_list_items{{ rid }}%,%&item{{ rid }}%");
    ELSE;
      SET(&string_list_items{{ rid }},%&item{{ rid }}%);
    ENDIF;
  NEXT;
  
  DO;
  
    {{
      UI.menu(
        items=[
          '§a← voltar',
          ' ',
          '§c%&owner'~rid~'%',
          '%&string_list_items'~rid~'%'
        ],
        outvar='&option'~rid,
        label='Selecione um dos serviços oferecidos por essa extensão §a§lMacrosoft§7® §o2022',
        strip=False
      ) 
    }}
    
    IF((!&option{{ rid }})||(&option{{ rid }}=="§a← voltar"));
      BREAK;
    ELSE;
      
      INDEXOF(&services{{ rid }}[],#index{{ rid }},%&option{{ rid }}%,true);
      IF(#index{{ rid }}>-1);
        
        SET(&servicename{{ rid }},%&option{{ rid }}%);
        &lines{{ rid }}="%&descriptions{{ rid }}[%#index{{ rid }}%]%";
        
        DO;
          {{
            UI.menu(
              items=[
                '§a← voltar',
                ' ',
                '%&lines'~rid~'%'
              ],
              outvar='&option'~rid,
              label='Saiba mais sobre o serviço §8§l[§f%&servicename'~rid~'%§8§l] §a§lMacrosoft§7® §o2022',
              strip=False
            ) 
          }}
            
          IF((!&option{{ rid }})||(&option{{ rid }}=="§a← voltar"));
            BREAK;
          ENDIF;
          
        LOOP;
  
      ENDIF;
    
    ENDIF;
  
  LOOP;



{* endmacro *}

/*
  NOME: consome um evento de uma extensão
  DESCRIÇÃO: esta macro chama uma extensão já
  instanciada. Indica-se um evento para ser
  consumido. 
  
  REMOVIDO:
    Se o evento retornar alguma mensagem prefixada por 'halt[:mensagem]' 
    então, indica-se que este evento deve ser bloqueado para execuções futuras.
    
  TODO: Em name e event usar somente caracteres alfatnuméricos e underline
*/
{* macro client_event(event, name='extension', timeout=None, outvar='&message'~nid(), success_outvar='success'~nid(), async=False, arguments=[]) *}
	
	{* set rand = nid() *}
	
	{* set event_name = event|replace("-","_")|replace(".","_")|lower()|replace_especial_alphabetic_chars() *} 
	
	UNSET({{ success_outvar }});
	
	{{ map_variable(context_variable(extension=name, name='enabled'),'enabled'~rand) }}
	{!! map_variable(context_variable(extension=name, name='halted'),'halted'~rand) !!}
	
	//IF((enabled{{ rand }})&&(!halted{{ rand }}));
	IF(enabled{{ rand }});
	/*IF(({{ 'extension_'~escaped_csid~'_'~name~'_enabled' }})&&(!{{ 'extension_'~escaped_csid~'_'~name~'_'~event_name~'_halted' }}));*/
	
	  {{ map_variable(context_variable(extension=name, name='info', prefix='&'),'&info'~rand) }}
	  
	  IFCONTAINS("%&info{{ rand }}%","{{ DICT.left_item_border~event~DICT.right_item_border~'→' }}");

      {* if async *}
      
        {{ CORTEX.send(name,'play!'~event~' '~arguments|join(',')) }}
        
      {* else *}
      
        {{ SERVICEPACK.play(pname=name,task=event, outvar=outvar, arguments=arguments, timeout=timeout) }}
            
        IF({{ outvar }});
          SET({{ success_outvar }});
          //IFMATCHES(%{{ outvar }}%,"^halt:?(.*)?",&message{{ rand }},1);
          //  UNSET({{ success_outvar }});//O halt faz o success_outvar ser 'false'
          //  {!! set_variable(context_variable(extension=name, name='halted')) !!}
          //  {!!SET({{ 'extension_'~escaped_csid~'_'~name~'_'~event_name~'_halted' }});!!}
          //  SET({{ outvar }},%&message{{ rand }}%);
          //ENDIF;     
        ENDIF;
            
      {* endif *}
      
    ELSE;
      {!! set_variable(context_variable(extension=name, name='halted')) !!}
      {!! SET({{ 'extension_'~escaped_csid~'_'~name~'_'~event_name~'_halted' }});!!}
      LOG("§4§l✗ §7§l{{ event }}");
    ENDIF;
    
  ENDIF;
	
{* endmacro *}

