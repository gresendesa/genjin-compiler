/*
  NOME: gera informações em um servidor
  DESCRIÇÃO: esta macro captura o desenvolvedor da extensão
  e os eventos aceitos pela extensão e atribui a uma variável
  'outvar'
  O parâmetro 'descriptions' recebe uma lista de objetos que devem conter
  os seguintes atributos: 
    - event: o nome do evento a ser descripto
    - alias: um nome apelido que será dado ao evento
    - details: uma lista de linhas que serão exibidas em menu
*/
{* macro server_generate_info(outvar='&info'~nid(), descriptions=[],disclamer='§3by §b'~dev) *}
	
	UNSET({{ outvar }});
	{* set events = [] *}

  {* set shared_tasks = [] *}
  {* set owners_shared_tasks = [] *}
  
  {* for dependencie in this.dependencies *}
    {* set foo = shared_tasks.append(dependencie.taskName) *}
    {* set foo = owners_shared_tasks.append(dependencie.dev) *}
  {* endfor *}
  
  {* for task in this.tasks + shared_tasks *}
    
    {* if task.name not in this.disabled_tasks *}
    
      {* set event_details = {} *}
      
      {* for description in descriptions *}
        
        {* set event_name = description.event *}
        
        {* if event_name == task.name *}
        
          {* set alias = description.alias *}
          {* set details = description.details *}
          {* set foo = event_details.update({event_name: alias~alias_separator~details|join(',')}) *}
        
        {* endif *}
      
      {* endfor *}
      
      {* if task.name != 'info'  *}
        {* set foo = events.append(DICT.left_item_border~task.name~DICT.right_item_border~'→'~DICT.left_item_border~event_details[task.name]~DICT.right_item_border) *}
      {* endif *}
      
    {* endif *}
    
  {* endfor *}
    
  SET({{ outvar }},"{{ disclamer~','~''.join(events) }}")
	
{* endmacro *}

