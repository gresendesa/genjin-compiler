{* macro testar_trocar_ferramenta(option, menu) *}
	{{ UI.DATA.load(menu) }}
	{*
		set test_prog = {
			ATTRIBUTE.NAME: programa[ATTRIBUTE.NAME],
			ATTRIBUTE.DESCRIPTION: 'Testa tudo!',
			ATTRIBUTE.VARIABLES: programa[ATTRIBUTE.VARIABLES],
			ATTRIBUTE.PROCEDURES: programa[ATTRIBUTE.PROCEDURES],
			ATTRIBUTE.BLOCK: BLOCOS_TRATAMENTO.ferramenta_gasta | place(ATTRIBUTE.VARIABLE, 'resultado')
		}
	*}
	{* macro yay(CORE) *}
		{* set variaveis_genjin = [] *}
		{{ CORE.variable.find.by_name('resultado', variaveis_genjin) }}
		{* set variavel_macro = {} *}
		{{ CORE.language.render_variable_name(CORE=CORE, variable=variaveis_genjin|first, jinja_out_var=variavel_macro) }}
		{{ CHAT.print('%'~variavel_macro[ATTRIBUTE.NAME]~'%', type='default', label='CÓDIGO DE SAÍDA DO TESTE') }}
	{* endmacro *}
	{{ GENJIN.build(prog=test_prog, language_renderer=MACROMOD, post_execution=yay) }}
{* endmacro *}

