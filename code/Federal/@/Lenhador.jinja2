						ENDIF;
					ELSEIF(block_removed{{ r }});
						BREAK;
					ENDIF;
				LOOP;
				KEYUP(FORWARD); KEYUP(JUMP);
				
				// Verificação de erros que interrompem o loop FOREACH
				IF(damaged_tool{{ r }});
					// ESTADO FINAL 3: Ferramenta gasta
					SET({{ outvar }},{{ RESULTADO.FERRAMENTA_GASTA }});
					SET(loop_completed_successfully{{ r }}, 0);
					BREAK;
				ELSEIF(block_too_far{{ r }});
					// ESTADO FINAL 4: Bloco muito longe
					SET({{ outvar }},{{ RESULTADO.BLOCO_MUITO_LONGE }});
					SET(loop_completed_successfully{{ r }}, 0);
					BREAK;
				ELSEIF(!block_removed{{ r }});
					// ESTADO FINAL 5: Demora para extrair
					SET({{ outvar }},{{ RESULTADO.DEMORA_EXTRAIR_BLOCO }});
					SET(loop_completed_successfully{{ r }}, 0);
					BREAK;
				ENDIF;
				
			NEXT;
			
			IF(loop_completed_successfully{{ r }});
				// ESTADO FINAL 6: Todos os blocos foram removidos (sucesso)
				SET({{ outvar }},{{ RESULTADO.SUCESSO }});
			ENDIF;
		ENDIF;
	ENDIF;
	
{* endmacro *}

{* macro exibir_exceção(outvar, resultado, pausar=True) *}
	{{ CHAT.print(resultado,'error','Exceção') }}
	{* if pausar *}
		DO;
		UNTIL(KEY_RETURN);
	{* endif *}
{* endmacro *}

{* macro tratar_exceção0(outvar, resultado) *}
	
	{{
		FLOW.switch(
			evaluate=resultado,
			cases=[
				(RESULTADO.SEM_ÁRVORES_AO_REDOR,  [(lidar_sem_árvores, {})]),
			],
			outvar='#res',
		)
	}}
	
	SET({{ outvar }},%#res%);
	
{* endmacro *}

