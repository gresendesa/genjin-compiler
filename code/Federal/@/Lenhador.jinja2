	UNTIL(KEY_RETURN);
	SET({{ outvar }},{{ RESULTADO.SUCESSO }});
{* endmacro *}

{* macro tratar_exceção(outvar, exceção) *}
	
	{{
		FLOW.switch(
			evaluate=exceção,
			cases=[
				(RESULTADO.DEMORA_EXTRAIR_BLOCO,              [(registrar_demora, {})]),
				(RESULTADO.SEM_MAIS_ÁRVORES_PARA_PROCESSAR,   [(todas_árvores_processadas, {})]),
				(RESULTADO.FERRAMENTA_GASTA,                  [(tratar_ferramenta_gasta, {})]),
			],
			outvar='#resultado2',
		)
	}}
	
	SET({{ outvar }},%#resultado2%);
	
{* endmacro *}

{* macro registrar_demora(outvar) *}
	{{ CHAT.print('Demora para extrair bloco','warning','Vamos continuar') }}
{* endmacro *}

{* macro todas_árvores_processadas(outvar) *}
	{{ CHAT.print('Processamos todas as árvores','success','Ótimo') }}
