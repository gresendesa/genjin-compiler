{* extends 'Federal.sketch.setup-code' *}
{* import 'Federal.sketch.genjin' as GENJIN *}
{* from "Federal.sketch.genjin" import MACROMOD, ATTRIBUTE, CARDINALITY, TYPE, EVALUATION, STAGE *}
{* import 'Macrosoft.common.control' as CONTROL *}
{* from "Federal.@.Lenhador" import RESULTADO *}
{* import 'Federal.text.chat' as CHAT *}
{* import 'Macrosoft.TASK.extension' as EXTENSION *}
{* import 'Macrosoft.TAXON.UI' as UI *}
{* import 'Federal.@.TemasUI' as TEMASUI *}
{* import 'Federal.@.FEDERAL_UI' as FEDERAL_UI *}
{* import "Federal.@.server_tools_cl_77_78" as SERVER_TOOLS *}

{* block code *}
	{!! GENJIN.build(prog=programa, language_renderer=MACROMOD, logger=SIMPLE_CODE_LOGGER) !!}
	{{ GENJIN.build(prog=programa, language_renderer=MACROMOD) }}
	LOG("SAÍ DO PROGRAMA. ISSO NÃO DEVERIA ACONTECER. CONTATE DO DEV.");
{* endblock *}

{* block setup *}
	{* set extensões_servidor_cl = [{'name': 'tools','id': 'server_tools_cl_77_78', 'success_outvar': 'ok'}] *}
	{{ CONTROL.switch(extensions=extensões_servidor_cl) }}
	{* macro cancelar(value, accept, reject) *}
		{{ CONTROL.turn_off(extensions=extensões_servidor_cl) }}
		{{ accept() }}
	{* endmacro *}
	
	IF(ok);
		{{ EXTENSION.service.event(name='tools', event='main', async=True) }}
		{*
			set mymenu = {
				'type': UI.TYPE.MENU,
				'name': 'principal',
				'label': 'Escolha',
				'short': 'Bem vindo ao Lenhador Inteligente do Federal',
				'breadcrumb': 'Início',
				'options': [
					{'type': UI.TYPE.BUTTON.SUBMIT},
					{'type': UI.TYPE.BUTTON.CANCEL},
					{'type': UI.TYPE.LINE.BLANK},
					
					{'type': UI.TYPE.LINE.DUMMY, 'text': '§8==§7§odefina essas homes§8=='},
					{'type': UI.TYPE.INPUT.VALUE, 'text': 'Baús guardar', 'name': 'mkb', 'label': 'digite a home', 'default':'mkb'},
					{'type': UI.TYPE.INPUT.VALUE, 'text': 'Machados gastos', 'name': 'red_axe', 'label': 'digite a home', 'default':'mkb_largar'},
					{'type': UI.TYPE.INPUT.VALUE, 'text': 'Machados novos', 'name': 'green_axe', 'label': 'digite a home', 'default':'mkb_pegar'},
					{'type': UI.TYPE.LINE.BLANK},
					{'type': UI.TYPE.LINE.DUMMY, 'text': '§8==§7§ovou definir essas§8=='},
					{'type': UI.TYPE.INPUT.VALUE, 'text': 'Temporária MKB', 'name': 'mkb_temp', 'label': 'digite a home', 'default':'mkb_temp'},
					{'type': UI.TYPE.INPUT.VALUE, 'text': 'Checkpoint', 'name': 'checkpoint', 'label': 'digite a home', 'default':'l'},
					{'type': UI.TYPE.LINE.BLANK},
					{'type': UI.TYPE.BUTTON.GENERIC, 'text': 'Testar trocar ferramenta', 'name': 'test0', 'action': testar_trocar_ferramenta},
					{'type': UI.TYPE.LINE.BLANK},
					{'type': UI.TYPE.BUTTON.RESET},
				],
				'outvars': {
					'mkb': '&home_guardar',
					'mkb_temp': '&home_guardar_temp',
					'red_axe': '&home_machados_red',
					'green_axe': '&home_machados_novos',
					'checkpoint': '&home_checkpoint',
				}
			}
		*}
		
		{* set preferências =  {} *}
		{* set _ = TEMASUI.TEMA_FEDERAL.update({
			'CANCEL_TEXT': 'Sair (ESC)!'
		}) *}
		{{ UI.SETTINGS.wrap(preferências, TEMASUI.TEMA_FEDERAL) }}
		
		{{ UI.build(menu_option=mymenu, settings=preferências, on_cancel=cancelar) }}
		{{ UI.DATA.load(mymenu) }}
	ELSE;
		{{ CONTROL.turn_off() }}
	ENDIF;
	
{* endblock *}

{* macro SIMPLE_CODE_LOGGER(CORE, blockcrumb, block, variable, from_code, stage) *}
	{* set outvar_variable_dict = {} *}
	{{ CORE.language.render_variable_name(CORE=CORE, variable=variable, jinja_out_var=outvar_variable_dict) }}
	{* if stage == STAGE.BEFORE_PROCEDURE *}
		{{ CHAT.print('%'~outvar_variable_dict[ATTRIBUTE.NAME]~'%', type='warning', label='[B] '~block[ATTRIBUTE.NAME]) }}
	{* elif stage == STAGE.AFTER_PROCEDURE *}
		{{ CHAT.print('%'~outvar_variable_dict[ATTRIBUTE.NAME]~'%', type='success', label='[A] '~block[ATTRIBUTE.NAME]) }}
	{* endif *}
{* endmacro *}

{* macro reiniciar_ciclo(outvar) *}
	LOG("Mandei reiniciar o ciclo");
	SET({{ outvar }},{{ RESULTADO.REINICIAR_CICLO }});
{* endmacro *}

{* macro reseta_variaveis(outvar, var_posicao_lista) *}
	SET({{ var_posicao_lista }},0);//Reseta a variável que armazena a posição da lista de árvores encontradas
	SET({{ outvar }},{{ RESULTADO.SUCESSO }});
{* endmacro *}

