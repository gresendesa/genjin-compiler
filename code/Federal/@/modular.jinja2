  ENDIF;

  IF((modular_debug_) || (@modular_debug_));
    LOG("§2§l%&script_name_% §n§8FROM§r§7%&last_% §n§8TO§r§7%&next_% §n§8ARGS§r§7%&stripargs_%");
  ENDIF;

  &next_="";
  &return_="";
  UNSET(break_);
  WAIT(10ms);
  
  UNTIL(finish_);
  UNSET("%&socket_%");
  UNSET("%&global_flag_%");

{* endmacro *}

/*
  NAME: Modular parser (unsafe)
  DESCRIPTION: It defines the tail for Modular programs.
*/
{* macro modular_parser(not_found_state, unsafe=None) *}

    //{% "parser.safe.txt" %}
    {{ modular_parser_safe(not_found_state) }}
  {* if unsafe != None *}
    ENDUNSAFE;
  {* endif *}
  
{* endmacro *}


/*=========================================

MODULAR ABSTRACTION FOR ROCKET 2021 HERE <- 2021abstraction

==========================================*/

/*
  NAME: Modular buid state 
  DESCRIPTION: It builds state based on string or object
*/
{* macro build_state(name, state, statevar='&current_') *}
  
  ELSEIF({{ statevar }}=="{{ name }}");
    {* if state is callable *}
      {{ state() }}
    {* elif state is string *}
      {{ state|macro() }}
    {* endif *}
    
{* endmacro *}

{* macro state_name_default_hook(name) -*}
  {{ name }}
{*- endmacro *}

{* macro default_not_found_state() *}
  
  SET(finish_);
  PLAYSOUND(note.bassattack);
  PLAYSOUND(block.note.bass);
  LOG("§8§o%&script_name_% §4§lError §r§eState §c%&current_%§e not found! Program aborted.");
    
{* endmacro *}

/*
  NAME: Modular generate
  DESCRIPTION: It generates a whole modular program based in its states
*/
{* macro generate(bootstrap=None, states=[], not_found_state=default_not_found_state, unsafe=None, include=['onkill', 'onresume', 'onpause', 'paused', 'read_socket', 'consume', 'start', 'plugin'], exclude=[], state_name_hook=state_name_default_hook, statevar='&current_', header=modular_initial, tail=modular_parser, inputs=modular_inputs) *}
  
  
  {* if inputs is callable *}
    {{ inputs() }}
  {* endif *}
  
  {* set filtered_default_states = [] *}
  
  //It exclude desired items from defaut_states
  {* for item in include *}
    {* if item not in exclude  *}
      {* set aux = filtered_default_states.append(item) *}
    {* endif *}
  {* endfor *}
  
  {* if bootstrap is callable *}
    
    {{ bootstrap() }}
    
  {* endif *}
  
  {{ header(unsafe=unsafe) }}
  
  {* for state in states *}
    
    {* if state is callable *}
      {* set name = state.name *}
    {* elif state is string *}
      {* set name = state *}
    {* endif *}
    {{ build_state(name=state_name_hook(name), state=state, statevar=statevar) }}
  
  {* endfor *}
  
  {* for state in filtered_default_states *}
    
    {{ build_state(name=state, state='modular_state_'~state, statevar=statevar) }}
  
  {* endfor *}

  {{ tail(not_found_state=not_found_state, unsafe=unsafe) }}
  
{* endmacro *}


/*=========================================

PLUGS ABSTRACTION FOR ROCKET 2021 HERE <- 2021plugs_abstraction

==========================================*/

/*
  NAME: Plugs generator
  DESCRIPTION: It generates the plugs
*/
{* macro plug(services, state_name_hook=state_name_default_hook, exclude=['onkill', 'onresume', 'onpause', 'consume', 'paused', 'read_socket', 'start', 'plugin']) *}

  {* macro plug_preamble(unsafe) *}
    {{ ibm_provider_start() }}
    &service_="%&pim_syn_message_%";
    IF(&service_=="");
	    LOG("§8§l[Plugin] §r§7service is §4empty!");
	    SET(&ibm_return_,"empty");
  {* endmacro *}

  {* macro info() *}
    {* set names = [] *}
    {* for service in services *}
      {* set foo = names.append(service.name) *}
    {* endfor *}
    SET(&ibm_return_,"{{ dev }},{{ names|join(',') }}");
  {* endmacro *}
  
  {* macro not_found() *}
    LOG("§8§l[Plugin] §r§7service §l%&service_% §r§4not found!");
    SET(&ibm_return_,"not_found");
  {* endmacro *}
  
  {* macro plug_ending(not_found_state=not_found, unsafe=None) *}
    
    ELSE;
      {{ not_found_state() }}
    ENDIF;
    
    {{ ibm_provider_stop() }}

  {* endmacro *}

  {{ 
    generate(
      states=[info]+services,
      exclude=exclude,
      not_found_state=not_found,
      statevar='&service_',
      header=plug_preamble,
      tail=plug_ending,
      inputs=None
    ) 
  }}

{* endmacro *}

$${

  {* macro mymacro() *}
  {* endmacro *}
  {* macro mymacro2() *}
  {* endmacro *}

  {{ plug(services=[mymacro, mymacro2]) }}
  {!! generate(states=[mymacro, mymacro2]) !!}
  
}$$
