  &pim_ack_message_="%#id_%";
  //{% "../ibm/provider_start.txt" %}
  {{ ibm_provider_start() }}
  
{* endmacro *}

/*
  NAME: Modular loop
  DESCRIPTION: It should be inserted into any loop on modular program.
               This is able to block program execution.
*/
{* macro modular_loop() *}

  SET(&socket_msg__,"%%&socket_%%");
  IFMATCHES(%&socket_msg__%,"^kill:.*?|^pause:.*?");
    SET(break_);
    BREAK;
  ELSE;
    IF((KEY_DELETE) || (break_));
      SET(break_);
      BREAK;
    ELSE;
      UNSET(break_);
    ENDIF;
  ENDIF;
  WAIT(10ms);
  
{* endmacro *}

