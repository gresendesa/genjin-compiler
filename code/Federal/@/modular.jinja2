/*
  NAME: Modular initial (safe)
  DESCRIPTION: It defines the header for Modular program
*/
{* macro modular_initial_safe() *}
  
  UNSET(finish_);
  UNSET(&last_);
  UNSET(&return_);
  UNSET(&stack_[]);
  &standby_=%&inputs_[11]%;
  #debug_=%#inputs_[12]%;
  &entrypoint_=%&current_%;
  &default_status_="running_";
  
  // ---------------------------------------------------
  //| If #debug_ is defined, debug variables are set
  // ---------------------------------------------------
  IF(#debug_==1);
    SET(modular_debug_);
    SET(modular_verbose_);
  ENDIF;
  
  // -----------------------------------------------------------------------------------
  //| It sends #id through channel defined on &pim_syn_message_ and creates the &socket_
  // -----------------------------------------------------------------------------------
  IF(&pim_syn_message_);
    &socket_="%&pim_syn_message_%%#id_%";
    SET("%&pim_syn_message_%","%&socket_%");
    &ibm_return_="ok";
    //{% "../ibm/provider_stop.txt" %} 
    {{ ibm_provider_stop() }}
    
  ENDIF;
  
  // ---------------------------------------------------
  //| It routes flow to paused if &standby_ is defined
  // ---------------------------------------------------
  IF(&standby_=="standby");
    SET(standby_);
    SET("%&socket_%","paused");
    &current_="paused";
  ENDIF;
  
  // ---------------------------------------------------
  //| It starts the main loop
  // ---------------------------------------------------
  DO;
    SET(&socket_message_,"%%&socket_%%");
    IFMATCHES("%&socket_message_%","^kill:.*");
      UNSET("%&socket_%");
      SET(kill_);
      IF(&last_!="paused");
        &current_="onkill";
      ELSE;
        &current_="exit";
      ENDIF;
    ELSE;
      IFMATCHES("%&socket_message_%","^pause:.*");
        SET("%&socket_%","paused");
        &current_="onpause";
      ENDIF;
      IF((&standby_=="standby") && (kill_==0) && ((&current_=="") || (&current_=="exit") || (finish_)));
        SET("%&socket_%","paused");
        &current_="paused";
      ENDIF;
    ENDIF;
  
    IF(KEY_DELETE);
      SET(finish_);
      LOG("§7DELETE §7§o%&script_name_%");
    ENDIF;
  
    IF((&current_=="") || (&current_=="exit") || (finish_));
      SET(finish_);
      SET(&ibm_return_,"");
      IF(&current_=="exit");
        SET(&ibm_return_,"%&args_[1]%");
      ENDIF;
      //{% "../ibm/provider_stop.txt" %}
      {{ ibm_provider_stop() }}
    
{* endmacro *}

/*
  NAME: Modular initial (unsafe)
  DESCRIPTION: It defines the header for Modular program
*/
{* macro modular_initial(unsafe=None) *}
  
  {* if unsafe != None *}
    UNSAFE({{ unsafe }});
  {* endif *}
    //{% "initial.safe.txt" %}
    {{ modular_initial_safe() }}
  
{* endmacro *}

