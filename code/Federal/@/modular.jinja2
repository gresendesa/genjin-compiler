/*
  NAME: Modular state ONKILL
  DESCRIPTION: It is a default state executed just before the macro killling
*/
{* macro modular_state_onkill() *}

  REPLACE(&socket_message_,"kill:","");
  IF((modular_verbose_) || (@modular_verbose_));
    LOG("§8§o%&script_name_% §7§lKill: §r§7%&socket_message_%");
  ENDIF;
  &next_="exit";
  
{* endmacro *}

/*
  NAME: Modular state ONPAUSE
  DESCRIPTION: It is a default state executed just before the macro is paused
*/
{* macro modular_state_onpause() *}

  IF((modular_verbose_) || (@modular_verbose_));
    LOG("§8§o%&script_name_% §7§lPause: §r§7%&socket_message_%");
  ENDIF;
  &next_="paused(%&last_%)";
  
{* endmacro *}

/*
  NAME: Modular state ONRESUME
  DESCRIPTION: It is a default state executed just before the macro is resumed
*/
{* macro modular_state_onresume() *}

  IF((modular_verbose_) || (@modular_verbose_));
    LOG("§8§o%&script_name_% §7§lResume: §r§7%&socket_message_%");
  ENDIF;
  SET("%&socket_%","resumed");
  &next_="%&args_[1]%";
  
{* endmacro *}

/*
  NAME: Modular state CONSUME
  DESCRIPTION: It is a default state for consuming a service from another process
*/
{* macro modular_state_consume() *}

  MATCH(%&args_[1]%,"([^=]+)(?:=>(.*))?",&cmd_snippets_[]);
  &origin_state_=%&last_%;
  MATCH(%&cmd_snippets_[1]%,"([^:]+):?(.*)?",{&socket_standby_,&entryp_});
  &callback_=%&cmd_snippets_[2]%;
  SET(&standby_socket_msg_,%%&socket_standby_%%);
  IF(&standby_socket_msg_=="paused");
    SET("%&socket_standby_%","resume:%&args_[2]%,%&args_[3]%,%&args_[4]%,%&args_[5]%,%&args_[6]%,%&args_[7]%,%&args_[8]%,%&args_[9]%,%&entryp_%");
    DO;
      SET(&channel_content_,%%&socket_standby_%%);

      IFMATCHES(%&channel_content_%,"^kill:.*?|^pause:.*?");
        BREAK;
      ELSE;
        IF(KEY_DELETE);
          BREAK;
        ENDIF;
      ENDIF;

      WAIT(10ms);
    WHILE(&channel_content_!="resumed");
    DO;
      SET(&channel_content_,%%&socket_standby_%%);
      IF((&channel_content_!="paused") && (&channel_content_!="resumed") && (&channel_content_!="ACK"));
        &captured_msg_=%&channel_content_%;
        SET("%&socket_standby_%","ACK");
      ENDIF;

      IFMATCHES(%&channel_content_%,"^kill:.*?|^pause:.*?");
        BREAK;
      ELSE;
        IF(KEY_DELETE);
          BREAK;
        ENDIF;
      ENDIF;

      WAIT(10ms);
    WHILE(&channel_content_!="paused");
    &next_="%&callback_%(%&captured_msg_%,%&origin_state_%,%&socket_standby_%)";
  ELSE;
    LOG("§8§o%&script_name_% §6§lWarning:§r§eSTANDBY socket §c%&socket_standby_%§e contains '%&standby_socket_msg_%' instead of 'paused'");
    &next_="%&callback_%(,%&origin_state_%,%&socket_standby_%)";
  ENDIF;
    
{* endmacro *}

/*
  NAME: Modular state PAUSED
  DESCRIPTION: It is a default state for pausing execution
*/
{* macro modular_state_paused() *}

  &resume_callback_=%&args_[1]%;
  UNSET(break_);
  DO;
    SET(&socket_message_,"%%&socket_%%");
    IFMATCHES("%&socket_message_%","^resume:.*?|^kill:.*?|^pause:.*?");
      SET(break_);
      IFMATCHES("%&socket_message_%","^resume:.*");
        REPLACE(&socket_message_,"resume:","");
        &next_="onresume(%&resume_callback_%)";
        IF(&standby_=="standby");
          MATCH(%&socket_message_%,"([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?",&inputs_[]);
          MATCH(%&socket_message_%,"([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?,?([^,]*)?",#inputs_[]);
          &next_="onresume(%&entrypoint_%)";
          IF(&inputs_[9]);
            &next_="onresume(%&inputs_[9]%)";
          ENDIF;
          //LOG("resume: entrypoint:%&entrypoint_% INPUTS: 1:%&inputs_[1]% 2:%&inputs_[2]% 3:%&inputs_[3]% 4:%&inputs_[4]% 5:%&inputs_[5]% 6:%&inputs_[6]% 7:%&inputs_[7]% 8:%&inputs_[8]% 9:%&inputs_[9]%");
        ENDIF;
      ENDIF;
    ELSE;
      WAIT(10ms);
    ENDIF;
  UNTIL((KEY_DELETE) || (break_));
  
{* endmacro *}

/*
  NAME: Modular state PLUGIN
  DESCRIPTION: It is a default state for communicating with IBM plugs
*/
{* macro modular_state_plugin() *}
  
  //&args_[1] = plugin required:service required
  //&args_[2] = callback state
  //&args_[3-8] = args

  MATCH(%&args_[1]%,"([^=]+)(?:=>(.*))?",{&service_request_,&plugin_callback_});
  MATCH(%&service_request_%,"([^:]+):?(.*)?",{&plugin_ref_,&service_name_});

  UNSET(&plugin_ref_snippets_[]);
  MATCH(%&plugin_ref_%,"([^@]+)@?(.*)?",&plugin_ref_snippets_[]);

  SET(&plugin_name_,%&plugin_ref_snippets_[1]%);
  SET(&plugin_socket_,%&plugin_ref_snippets_[2]%);
  UNSET(plugin_standby_);
  IF(&plugin_socket_);
    SET(plugin_standby_);
  ENDIF;

  IF(plugin_standby_);

    LOG("§8§l[PLUGIN] §6Starting §8STANDBY §f%&service_name_%§8@§7%&plugin_name_%");

    FOR(#i,1,4);
      IF(#i==1);
        &interact_="ON(%&plugin_socket_%) NOTWRITE() AND WAIT UNTIL(paused)";
      ELSEIF(#i==2);
        &interact_="ON(%&plugin_socket_%) WRITE(resume:%&service_name_%,%&args_[2]%,%&args_[3]%,%&args_[4]%,%&args_[5]%,%&args_[6]%,%&args_[7]%,%&args_[8]%,%&plugin_name_%) AND WAIT UNTIL(resumed)";
      ELSEIF(#i==3);
        &interact_="ON(%&plugin_socket_%) NOTWRITE() AND WAIT WHILE(resumed)";
      ELSEIF(#i==4);
        SET(&ibm_response_,%&interact_message_%);
        SET(#ibm_success_,1);
        &interact_="ON(%&plugin_socket_%) WRITE(pause: Ok. Good job) AND WAIT UNTIL(paused)";
      ENDIF;
      //{% "socket.interact.txt" %}
      {{ modular_socket_interact() }}
    NEXT;

  ELSE;

    LOG("§8§l[PLUGIN] §6Starting §f%&service_name_%§8@§7%&plugin_name_%");

    &ibm_request_="%&plugin_name_%:%&service_name_%(%&args_[2]%¬%&args_[3]%¬%&args_[4]%¬%&args_[5]%¬%&args_[6]%¬%&args_[7]%¬%&args_[8]%)";

    //{% "../ibm/requester.txt" %}
    {{ ibm_requester() }}

  ENDIF;

  IF(#ibm_success_);
    LOG("§8§l[PLUGIN] §6OK. §aDone. §6Msg: §f%&ibm_response_%");
    INC(#agent_activate_counter);
  ELSE;
    LOG("§8§l[PLUGIN] §4Woops. Something went wrong");
  ENDIF;

  &next_="%&last_%(%&ibm_response_%,%&service_name_%,%#ibm_success_%)";
  IF(&plugin_callback_);
    &next_="%&plugin_callback_%(%&ibm_response_%,%&service_name_%,%#ibm_success_%)";
  ENDIF;
      
{* endmacro *}

/*
  NAME: Modular state READ_SOCKET
  DESCRIPTION: It is a default state for reading socket
*/
{* macro modular_state_read_socket() *}

  &socket_input_=%&args_[1]%;
  &callback_=%&args_[2]%;
  SET(%&socket_%,%&socket_input_%);
  UNSET(break_);
  DO(100);
    SET(&socket_message_,"%%&socket_%%");
    IFMATCHES("%&socket_message_%","^kill:.*?|^pause:.*?");
      SET(break_);
    ELSEIF(&socket_message_!=%&socket_input_%);
      IF((modular_verbose_) || (@modular_verbose_));
        LOG("§8§o%&script_name_% §7§lSocket§8§lReading: §r§7%&socket_message_%");
      ENDIF;
      &next_="%&callback_%(%&socket_message_%)";
      SET(break_);
    ELSE;
      WAIT(10ms);
    ENDIF;
  UNTIL((KEY_DELETE) || (break_));
  IF((!KEY_DELETE) && (!break_));
    &next_="%&callback_%(timeout_)";
    LOG("§8§o%&script_name_% §7§lSocket§8§lReading§7§lTimeout§8§lReached");
  ENDIF;
  
{* endmacro *}

/*
  NAME: Modular state START
  DESCRIPTION: It is a default state for starting a proccess
*/
{* macro modular_state_start() *}

  MATCH(%&args_[1]%,"([^=]+)(?:=>(.*))?",&cmd_snippets_[]);
  MATCH(%&cmd_snippets_[1]%,"([^:]+):?(DEBUG)?",&file_name_snippets_[]);
  &file_name_=%&file_name_snippets_[1]%;
  &debug_str_=%&file_name_snippets_[2]%;
  &origin_state_=%&last_%;
  &global_flag_="@&%&file_name_%_%#id_%";
  MATCH(%&cmd_snippets_[2]%,"([^:]+):?(SYNC|ASYNC|STANDBY)?",&callback_snippets_[]);
  &callback_="%&callback_snippets_[1]%";
  SET("%&global_flag_%",%&default_status_%);
  &standby_flag_="";
  IFMATCHES(%&callback_snippets_[2]%,"^STANDBY$");
    &standby_flag_="standby";
  ENDIF;
  #debug_flag_=0;
  IF(&debug_str_!="");
    #debug_flag_=1;
  ENDIF;

  UNSET(&channel_name_);
  IFMATCHES(%&callback_snippets_[2]%,"^(ASYNC|STANDBY)$");

    &channel_name_=%&global_flag_%;
    
  ENDIF;

  UNSET(&pim_syn_message_);

  IFMATCHES(%&callback_snippets_[2]%,"^(ASYNC|STANDBY)$");

    &pim_syn_message_="%&global_flag_%";
    
  ENDIF;

  IF(standalone_);
    &ibm_request_="%&standalone_filename_%:%&pim_syn_message_%(%&args_[2]%¬%&args_[3]%¬%&args_[4]%¬%&args_[5]%¬%&args_[6]%¬%&args_[7]%¬%&args_[8]%¬%&args_[9]%¬%&file_name_%¬%&channel_name_%¬%&standby_flag_%¬%#debug_flag_%)";
  ELSE;
    &ibm_request_="%&file_name_%.exe:%&pim_syn_message_%(%&args_[2]%¬%&args_[3]%¬%&args_[4]%¬%&args_[5]%¬%&args_[6]%¬%&args_[7]%¬%&args_[8]%¬%&args_[9]%¬¬%&channel_name_%¬%&standby_flag_%¬%#debug_flag_%)";
  ENDIF;

  //{% "../ibm/requester.txt" %}
  {{ ibm_requester() }}

  IFMATCHES(%&callback_snippets_[2]%,"^(ASYNC|STANDBY)$");
  	
    &socketflag_="%&global_flag_%%&pim_ack_message_%";
    SET(&scontent_,%%&socketflag_%%);
    IF(&scontent_=="");
    	SET(%&socketflag_%," ");
    ENDIF;

    &next_="%&callback_%(%&socketflag_%,%&origin_state_%,%&file_name_%,%#ibm_success_%)";

  ELSE;

    &next_="%&callback_%(%&ibm_response_%,%&origin_state_%,%&file_name_%,%#ibm_success_%)";
    
  ENDIF;

  UNSET(%&global_flag_%);

{* endmacro *}

