/*
  NAME: Modular socket INTERACT
  DESCRIPTION: It is a snippet that interacts in real time with other modular programs
*/
{* macro modular_socket_interact() *}

  &interact_pattern_="ON\(([^\)]+)\) (WRITE|NOTWRITE)\(([^\)]*)\) AND WAIT (UNTIL|WHILE)\(([^\)]*)\)";
  UNSET(break_);
  IFMATCHES(%&interact_%,"%&interact_pattern_%");
    MATCH(%&interact_%,"%&interact_pattern_%",{&interact_socket_,&interact_writeness_,&interact_write_content_,&interact_wait_criteria_,&interact_wait_value_});
    //LOG("[interact]%&interact_socket_%  %&interact_writeness_%  %&interact_write_content_%  %&interact_wait_criteria_%  %&interact_wait_value_%");
    IF((modular_verbose_interact_) || (@modular_verbose_interact_));
      MATCH(%&interact_socket_%,"@&([a-z_]+)[0-9]+",{&socket_alias_});
      LOG("§6§l%&script_name_% §n§8TO§r§7%&socket_alias_% §n§8%&interact_writeness_%§r§7%&interact_write_content_% §n§8WAIT§r§7%&interact_wait_criteria_% %&interact_wait_value_%");
    ENDIF;
    IF(&interact_socket_);
      SET(&interact_message_,%%&interact_socket_%%);
      IF(&interact_message_);
        IFMATCHES(%&interact_writeness_%,"^WRITE$");
          SET(%&interact_socket_%,%&interact_write_content_%);
        ENDIF;
        DO;
  
          IF((modular_verbose_interact_) || (@modular_verbose_interact_));
            MATCH(%&interact_socket_%,"@&([a-z_]+)[0-9]+",{&socket_alias_});
            LOG("§6§l%&script_name_% §n§8TO§r§7%&socket_alias_% §n§8%&interact_writeness_%§r§7%&interact_write_content_% §n§8WAIT§r§7%&interact_wait_criteria_% %&interact_wait_value_%");
          ENDIF;
  
          SET(&interact_message_,%%&interact_socket_%%);
          SET(&parent_socket_msg_,"%%&socket_%%");
          IFMATCHES(%&parent_socket_msg_%,"^kill:.*?|^pause:.*?");
            SET(break_);
            BREAK;
          ELSE;
            IF((KEY_DELETE) || (break_));
              SET(break_);
              BREAK;
            ELSE;
              UNSET(break_);
            ENDIF;
          ENDIF;
          WAIT(77ms);
        UNTIL(((&interact_message_==%&interact_wait_value_%) && (&interact_wait_criteria_=="UNTIL")) || ((&interact_message_!=%&interact_wait_value_%) && (&interact_wait_criteria_=="WHILE")));
        IFMATCHES(%&interact_write_content_%,"^kill:");
          UNSET(%&interact_socket_%);
        ENDIF;
      //ELSE;
        //LOG("[interact] socket is empty");
      ENDIF;
    ENDIF;
  
    IF((modular_verbose_interact_) || (@modular_verbose_interact_));
      LOG("§6§l%&script_name_% §n§8RESULT§r§7%&interact_message_%");
    ENDIF;
  
    IF((modular_log_) || (@modular_log_));
      LOGTO("modular.txt","(INTERACT) %DATETIME% %&script_name_% (%#id_%) FROM%&interact_% RESULT%&interact_message_%");
    ENDIF;
  
  //ELSE;
    //LOG("[interact] sintax error");
  ENDIF;

{* endmacro *}

/*
  NAME: Modular socket WAIT
  DESCRIPTION: It is a snippet that wait for a criteria to be satisfied
*/
{* macro modular_socket_wait() *}

  MATCH(%&wait_%,"FOR ([a-z0-9&@_]*) (UNTIL|WHILE) ([\w]*)",{&wait_socket_name_,&wait_criteria_,&wait_value_});
      
  IF(&wait_socket_name_);
    DO;
      SET(&wait_message_,%%&wait_socket_name_%%);
      SET(&socket_msg_,"%%&socket_%%");
      IFMATCHES(%&socket_msg_%,"^kill:.*?|^pause:.*?");
        SET(break_);
        BREAK;
      ELSE;
        IF((KEY_DELETE) || (break_));
          SET(break_);
          BREAK;
        ELSE;
          UNSET(break_);
        ENDIF;
      ENDIF;
      WAIT(10ms);
    UNTIL(((&wait_message_==%&wait_value_%) && (&wait_criteria_=="UNTIL")) || ((&wait_message_!=%&wait_value_%) && (&wait_criteria_=="WHILE")));
  ENDIF;

{* endmacro *}

