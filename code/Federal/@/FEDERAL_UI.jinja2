						SET(&label{{ rand }},"{{ settings.INPUT_VALUE_LABEL_COLOR ~ '%' ~ _prompt_label_outvar ~ '%' ~ ' ' if option.label else '' }}%{{ formatted_warningvar }}%");
						IF(CLOUDMC);
							STRIP(&label{{ rand }},%&label{{ rand }}%);
						ENDIF;
						
						PROMPT("{{ readvar }}","$$?","%&label{{ rand }}%",true,%{{ outvar }}%);
						UNSET({{ warningvar }});
						{* if has_validator *}
							
							{* macro validate(updated_value=None) *}
								{* if updated_value != None *}
									SET({{ readvar }},"{{ updated_value }}");
								{* endif *}
								SET({{ successvar }});
							{* endmacro *}
							{* macro reprehend(text) *}
								SET({{ warningvar }},"{{ text }}");
							{* endmacro *}
							{{ option.validator(value='%'~readvar~'%',accept=validate, reject=reprehend) }}
							{{ 'UNTIL(('~successvar~')||(!'~readvar~'));' }}
							{{ 'IF('~successvar~');' }}
							
						{* endif *}
						
						REPLACE({{ readvar }},",","?");
						REPLACE({{ readvar }},"[","?");
						REPLACE({{ readvar }},"]","?");
						REPLACE({{ readvar }},"|","?");
						REPLACE({{ readvar }},"$","?");
						
						{{ DICT.update(source=storage_name, dict={storage_key: '%'~readvar~'%'}, global=True) }}
						SET({{ outvar }},%{{ readvar }}%);
						
						{* if has_validator *}
							{{ 'ENDIF;' }}
						{* endif *}
						
					{* endif *}
					
					{* if not loop.last *}
						
						{{ 'ELSE;' if loop.index0 % 2 == 0 else 'else;' }}
						{* set _ = endif_list.append('ENDIF;' if loop.index0 % 2 == 0 else 'endif;') *}
						
					{* else *}
						
						{!! if menu_option.meta_type != TYPE.PANEL.LIST !!}
						{{ 'ENDIF;' if loop.index0 % 2 == 0 else 'endif;' }}
						{!! endif !!}
						
					{* endif *}
					
					
				{* else *}
					
				{* endif *}
				
			{* endfor *}
			
			{* if menu_option.meta_type == TYPE.PANEL.LIST *}
				
				IF({{ choice_variable }});
					
					{* import 'Federal.INTEL.string' as STRING *}
					SET(&choice_copy{{ rand }},"%{{ choice_variable }}%");
					SET(&stripped_snippet{{ rand }},"{{ '^'~item_list_formatting }}");
					STRIP(&stripped_snippet{{ rand }},%&stripped_snippet{{ rand }}%);
					{{ STRING.replaceall(string_var='&choice_copy'~rand, searchfor='%&stripped_snippet'~rand~'%', replacewith='') }}
					
					{* set copy_source = 'list'~nid() *}
					{* set copy_value_var = '&element'~nid() *}
					{* set parent_menu = history | last *}
					
					{* import 'Federal.data_structures.list' as LIST *}
					{* import 'Federal.data_structures.dict' as DICT *}
					
					{* set parent_menu_name = menu_option.parent_menu_name *}
					{* set panel_storage_key = get_storage_key(parent_menu_name, menu_option.name) *}
					
					{* set outvar = get_outvar_from_item_name(name=menu_option.name, menu_option=parent_menu, storage_key=panel_storage_key, rand=rand) *}
					{{ DICT.get(source=storage_name, key=panel_storage_key, outvar='&'~copy_source, global=True) }}
					
					{{ LIST.get(source=copy_source,regex='\Q'~'%&choice_copy'~rand~'%'~'\E', outvar=copy_value_var) }}
					
					IF({{ copy_value_var }});
						
						//Essa parte decide se o elemento deve ser removido da lista
						{* set successvar = 'success'~nid() *}
						SET({{ successvar }});
						{* set has_delete_validator = 'delete_validator' in menu_option and menu_option.delete_validator is callable *}
						
						{* if has_delete_validator *}
							
							{* macro validate() *}
							{* endmacro *}
							
							{* macro reprehend(text) *}
								UNSET({{ successvar }});
								SET({{ menu_warningvar }},"{{ text }}");
							{* endmacro *}
							
							{{ menu_option.delete_validator(value='%&choice_copy'~rand~'%', accept=validate, reject=reprehend) }}
							
						{* endif *}
						
						//Essa parte deleta o elemento da lista
						IF({{ successvar }});
							REPLACE(&{{ copy_source }},"{{ LIST.left_item_border }}%&choice_copy{{ rand }}%{{ LIST.right_item_border }}","");
							{{ DICT.update(storage_name, {panel_storage_key: '%&' ~ copy_source ~ '%'}, global=True) }}
						ENDIF;
					ENDIF;
					
				ENDIF;
				
			{* endif *}
			
			{* for end_if in endif_list *}
				{{ end_if }}
			{* endfor *}
			
		{* endif *}
		
		{* if history|length == 0 *}
			
			IF((!&choice{{ rand }})||(&choice{{ rand }}=="{{ (settings.CANCEL_ICON ~ settings.ICON_SEPARATOR if settings.ICON_PRESENCE else '') ~ settings.CANCEL_TEXT }}"));
				
				{* if on_cancel is callable *}
					
					{* set successvar = 'success'~nid() *}
					
					//UNSET({{ successvar }});
					
					{* macro validate() *}
						SET({{ successvar }});
					{* endmacro *}
					
					{* macro reprehend(text) *}
						SET({{ menu_warningvar }},"{{ text }}");
						SET(&choice{{ rand }},"{{ nid()~nid()~nid() }}");
					{* endmacro *}
					
					{{ on_cancel(value='%&choice'~rand~'%', accept=validate, reject=reprehend) }}
					
					{* if settings.STOP_ON_CANCEL *}
						IF({{ successvar }});
							STOP("{{ this.name }}");
						ENDIF;
					{* endif *}
					
				{* else *}
					
					{* if settings.STOP_ON_CANCEL *}
						STOP;
					{* endif *}
					
				{* endif *}
				
			ELSEIF(&choice{{ rand }}=="{{ (settings.SUBMIT_ICON ~ settings.ICON_SEPARATOR if settings.ICON_PRESENCE else '') ~ settings.SUBMIT_TEXT }}");
				
				{* if on_submit is callable *}
					
					{* set successvar = 'success'~nid() *}
					
					//UNSET({{ successvar }});
					
					{* macro validate() *}
						SET({{ successvar }});
					{* endmacro *}
					
					{* macro reprehend(text) *}
						SET({{ menu_warningvar }},"{{ text }}");
					{* endmacro *}
					
					{{ on_submit(value='%&choice'~rand~'%', accept=validate, reject=reprehend) }}
					
					IF({{ successvar }});
						BREAK;
					ENDIF;
					
				{* else *}
					
					BREAK;
					
				{* endif *}
				
			ENDIF;
			
		{* endif *}
		
	UNTIL((!&choice{{ rand }})||(&choice{{ rand }}=="{{ (settings.BACK_ICON ~ settings.ICON_SEPARATOR if settings.ICON_PRESENCE else '') ~ settings.BACK_TEXT }}"));
	
{* endmacro *}


