{* macro get_outvar_from_item_name(name, menu_option, storage_key, rand) -*}
	{*- set outvar = menu_option.outvars[name] -*}
	{{ outvar if outvar else '&'~storage_key~rand }}
{*- endmacro *}

{* macro destroy_menu_data(settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{{ DICT.destroy(source=storage_name, global=True) }}
{* endmacro *}

{* macro get_storage_key(menu_name, item_name) -*}
	{{ menu_name ~'_'~ item_name }}
{*- endmacro *}

{* macro db_is_there_record(name, menu, outvar, settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set storage_key = get_storage_key(menu, name) *}
	{{ DICT.key_exists(source=storage_name, key=storage_key, outvar=outvar, global=True) }}
{* endmacro *}
{* macro db_get_record(name, menu, outvar, settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set storage_key = get_storage_key(menu, name) *}
	{{ DICT.get(source=storage_name, key=storage_key, outvar=outvar, global=True) }}
{* endmacro *}
{* macro db_set_record(name, menu, content, settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set storage_key = get_storage_key(menu, name) *}
	{{ DICT.update(source=storage_name, dict={storage_key: content}, global=True) }}
{* endmacro *}
{* macro db_remove_record(name, menu, settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set storage_key = get_storage_key(menu, name) *}
	{{ DICT.update(source=storage_name, key=storage_key, global=True) }}
{* endmacro *}
{* macro destroy_database(settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{{ DICT.destroy(source=storage_name, global=True) }}
{* endmacro *}

