{* macro load_menu_data(menu_option, menu_name=None, option_name=None, option_outvar=None, settings=DEFAULT_SETTINGS) *}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set rand = nid() *}
	{* set checkbox_list = [] *}
	
	{* if menu_option.type == TYPE.MENU *}
		/* 1. Lê a base de dados deste menus */
		{* for option in menu_option.options *}
			
			{!! if menu_name == None or option_name == None or option_outvar == None or (menu_name == menu_option.name and option_name == option.name)  !!}
			
			{* set pick_load_mode = menu_name != None and option_name != None and option_outvar != None *}
			{* set picking_matches = (not pick_load_mode) or (menu_name == menu_option.name and option_name == option.name) *}
			
			{* set storage_key = get_storage_key(menu_option.name, option.name) *}
			
			{* if picking_matches and (option.type == TYPE.PANEL.LIST or option.meta_type == TYPE.PANEL.LIST) *}
				
				{{ warning_dependencies_missing() }}
				
				{* set copy_source = 'list'~nid() *}
				{* set parent_menu_name = menu_option.name *}
				{* set panel_storage_key = get_storage_key(parent_menu_name, option.name) *}
				{* set outvar = get_outvar_from_item_name(name=option.name, menu_option=menu_option, storage_key=panel_storage_key, rand=rand) if not pick_load_mode else option_outvar *}
				{{ DICT.key_exists(source=storage_name, key=panel_storage_key, outvar='key_exists'~rand, global=True) }}
				
				IF(!key_exists{{ rand }});
					{* for item in option.default *}
						PUT({{ outvar }}[],"{{ item }}");
					{* endfor *}
				ELSE;
					{{ DICT.get(source=storage_name, key=panel_storage_key, outvar='&'~copy_source, global=True) }}
					SET(&temp_list{{ rand }},%&{{ copy_source }}%);
					IF(&temp_list{{ rand }});
						{{ STRING.replaceall(string_var='&temp_list'~rand, searchfor='^'~LIST.left_item_border, replacewith='') }}
						{{ STRING.replaceall(string_var='&temp_list'~rand, searchfor=LIST.right_item_border~'$', replacewith='') }}
						{{ STRING.explode(string='%&temp_list'~rand~'%', array=outvar~'[]', delimiter=LIST.right_item_border~LIST.left_item_border) }}
					ENDIF;
					
				ENDIF;
				
			{* elif option.type == TYPE.MENU *}
				
				{{ load_menu_data(menu_option=option, menu_name=menu_name, option_name=option_name, option_outvar=option_outvar, settings=settings) }}
				
			{* elif picking_matches and option.type == TYPE.INPUT.CHECKBOX *}
				
				{* set outvar = get_outvar_from_item_name(name=option.name, menu_option=menu_option, storage_key=storage_key, rand=rand) if not pick_load_mode else option_outvar *}
				{* set copy_source = 'list'~nid() *}
				{* set copy_value_var = '&element'~nid() *}
				
				{* if checkbox_list|length <= 0 *}
					UNSET({{ outvar }}[]);
				{* endif *}
				
				{* set _ = checkbox_list.append(option) *}
				
				{* if option.default *}
					
					{{ DICT.key_exists(source=storage_name, key=storage_key, outvar='key_exists'~rand, global=True) }}
					
					IF(!key_exists{{ rand }});
						SET({{ copy_value_var }},"{{ option.value }}");
					ELSE;
						{{ DICT.get(storage_name, storage_key, outvar='&'~copy_source, global=True) }}
						{{ LIST.get(source=copy_source,regex='\Q'~option.value~'\E', outvar=copy_value_var) }}
					ENDIF;
					
					IF({{ copy_value_var }});
						PUT({{ outvar }}[],%{{ copy_value_var }}%);
					ENDIF;
					
				{* else *}
					
					{{ DICT.get(storage_name, storage_key, outvar='&'~copy_source, global=True) }}
					{{ LIST.get(source=copy_source,regex='\Q'~option.value~'\E', outvar=copy_value_var) }}
					IF({{ copy_value_var }});
						PUT({{ outvar }}[],%{{ copy_value_var }}%);
					ENDIF;
					
				{* endif *}
				
			{* elif picking_matches and option.type == TYPE.INPUT.RADIO *}
				
				{* set outvar = get_outvar_from_item_name(name=option.name, menu_option=menu_option, storage_key=storage_key, rand=rand) if not pick_load_mode else option_outvar *}
				{* set aux_outvar = '&copy'~rand *}
				
				{* if option.default *}
					{{ DICT.key_exists(source=storage_name, key=storage_key, outvar='key_exists'~rand, global=True) }}
					IF(!key_exists{{ rand }});
						SET({{ outvar }},"{{ option.value }}");
					ELSE;
						{{ DICT.get(storage_name, storage_key, outvar=aux_outvar, global=True) }}
					ENDIF;
				{* else *}
					{{ DICT.get(storage_name, storage_key, outvar=aux_outvar, global=True) }}
					IF({{ aux_outvar }});
						SET({{ outvar }},%{{ aux_outvar }}%);
					ENDIF;
				{* endif *}
				
			{* elif picking_matches and option.type == TYPE.DATA *}
				
				{* set outvar = get_outvar_from_item_name(name=option.name, menu_option=menu_option, storage_key=storage_key, rand=rand) if not pick_load_mode else option_outvar *}
				
				{* if option.default *}
					{{ DICT.key_exists(source=storage_name, key=storage_key, outvar='key_exists'~rand, global=True) }}
					IF(!key_exists{{ rand }});
						SET({{ outvar }},"{{ option.default if option.default else '' }}");
					ELSE;
						{{ DICT.get(storage_name, storage_key, outvar, global=True) }}
					ENDIF;
				{* else *}
					{{ DICT.get(storage_name, storage_key, outvar, global=True) }}
				{* endif *}
				
			{* elif picking_matches and option.type == TYPE.INPUT.VALUE *}
				
				{* set outvar = get_outvar_from_item_name(name=option.name, menu_option=menu_option, storage_key=storage_key, rand=rand) if not pick_load_mode else option_outvar *}
				
				{* if option.default *}
					{{ DICT.key_exists(source=storage_name, key=storage_key, outvar='key_exists'~rand, global=True) }}
					IF(!key_exists{{ rand }});
						SET({{ outvar }},"{{ option.default if option.default else '' }}");
					ELSE;
						{{ DICT.get(storage_name, storage_key, outvar, global=True) }}
					ENDIF;
				{* else *}
					{{ DICT.get(storage_name, storage_key, outvar, global=True) }}
				{* endif *}
				
			{* endif *}
			
			{!! endif !!}
			
		{* endfor *}
	{* endif *}
{* endmacro *}

{* set OPTION_OUTVAR_ID = nid() *}



/**
	* Essa macro possui uma funcionalidade gostosinha de buscar as informações na base de dados
	* ou na descrição do menu para obter valores padrão, cuidando, ao mesmo tempo, de
	* não realizar consultas redundantes dentro do contexto de um menu - para economizar código.
	*
	* O histórico de buscas fica no dicionário 'option_content_read_menu_history'.
	* Este dicionário guarda chaves referentes ao nome de um menu. Cada uma dessas chaves armazena
	* uma lista contendo a junção do nome do menu e da opção (menu_name~'_'~option_name)
	*
	* Essa função é a responsável pela busca de informação para o suporte a variáveis nos textos
	* das opções e nos textos dos labels.
	*
**/

{* set option_content_read_menu_history = {} *}
{* macro process_option_text(option, option_menu, outvar, global_menu, settings=DEFAULT_SETTINGS) *}
	{* set context_menu_name = option_menu.name *}
	{* set data_marks = option.text | findall('\[[a-z0-9_.]+\]') *}
	{* set option_text = {'text': option.text} *}
	UNSET({{ outvar }});
	{* if data_marks | length > 0 *}
		{* for mark in data_marks *}
			{* set mark_text = mark | replace('[','') | replace (']','') *}
			{* set mark_text_snippets = mark_text.split('.') *}
			{* set menu_name, option_name = (mark_text_snippets[0] if mark_text_snippets | length > 1 else context_menu_name), (mark_text_snippets[1] if mark_text_snippets | length > 1 else mark_text_snippets[0]) *}
			{* set unique_key = menu_name~'_'~option_name *}
			{* set option_outvar = '&option_'~unique_key~OPTION_OUTVAR_ID *}
			{* if unique_key not in option_content_read_menu_history[context_menu_name] *}
				{{ load_menu_data(menu_option=global_menu, menu_name=menu_name, option_name=option_name, option_outvar=option_outvar, settings=DEFAULT_SETTINGS) }}
				{* set menu_history = option_content_read_menu_history[context_menu_name] if context_menu_name in option_content_read_menu_history and option_content_read_menu_history[context_menu_name] is iterable and option_content_read_menu_history[context_menu_name] is not string else [] *}
				{* set _ = menu_history.append(unique_key) *}
				{* set _ = option_content_read_menu_history.update({context_menu_name: menu_history}) *}
			{* endif *}
			{* set _ = option_text.update({'text': option_text.text | replace(mark, '%'~option_outvar~'%')}) *}
		{* endfor *}
	{* endif *}
	SET({{ outvar }},"{{ option_text.text }}");
{* endmacro *}

{* macro call_item_action(option, menu_context) *}
	
	{* if option.action and option.action is callable *}
		{{ option.action(option=option, menu=menu_context) }}
	{* endif *}
	
	//, DB=DB_MANAGER
	
{* endmacro *}

