		LOG("§e[!] §cINTEL support not found!");
		{* if fatal *}
			STOP();
		{* endif *}
	ENDIF;
{* endmacro *}

{* macro db_get_list_record(name, menu, outvar, settings=DEFAULT_SETTINGS) *}
	{{ warning_dependencies_missing() }}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set storage_key = get_storage_key(menu, name) *}
	{* set temp_outvar = '&out_var'~nid() *}
	{{ DICT.get(source=storage_name, key=storage_key, outvar=temp_outvar, global=True) }}
	
	{{ STRING.replaceall(string_var='&temp_list'~rand, searchfor='^'~LIST.left_item_border, replacewith='') }}
	{{ STRING.replaceall(string_var='&temp_list'~rand, searchfor=LIST.right_item_border~'$', replacewith='') }}
	{{ STRING.explode(string='%&temp_list'~rand~'%', array=outvar~'[]', delimiter=LIST.right_item_border~LIST.left_item_border) }}
	
	{{ ARRAY.join(array=outvar~'[]', outvar='&panel_items'~rand, glue=','~item_list_formatting) }}
	
{* endmacro *}

{* macro db_set_list_record(name, menu, arrayvar, settings=DEFAULT_SETTINGS) *}
	{{ warning_dependencies_missing() }}
	{* set storage_name = settings.GLOBAL_DICT_STORAGE_NAME *}
	{* set storage_key = get_storage_key(menu, name) *}
	{{ DICT.update(source=storage_name, dict={storage_key: content}, global=True) }}
	
{* endmacro *}

