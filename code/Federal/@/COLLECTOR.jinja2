		'on_auto_crafting_complete': 'onAutoCraftingComplete',
		'on_config_change': 'onConfigChange',
		'on_send_chat_message': 'onSendChatMessage',
		'on_websocket_message': 'onWebSocketMessage'
	}
*}


{*
	set PORTS = {
		EVENTS.on_join_game: 1000,
		EVENTS.on_chat: 1001,
		EVENTS.on_health_change: 1002,
		EVENTS.on_food_change: 1003,
		EVENTS.on_armour_change: 1004,
		EVENTS.on_world_change: 1005,
		EVENTS.on_mode_change: 1006,
		EVENTS.on_inventory_slot_change: 1007,
		EVENTS.on_oxygen_change: 1008,
		EVENTS.on_xp_change: 1009,
		EVENTS.on_level_change: 1010,
		EVENTS.on_item_durability_change: 1011,
		EVENTS.on_weather_change: 1012,
		EVENTS.on_pickup_item: 1013,
		EVENTS.on_player_joined: 1014,
		EVENTS.on_show_gui: 1015,
		EVENTS.on_armour_durability_change: 1016,
		EVENTS.on_auto_crafting_complete: 1017,
		EVENTS.on_config_change: 1018,
		EVENTS.on_send_chat_message: 1019,
		EVENTS.on_websocket_message: 1100
	}
*}


{* macro add_event_collectors(events=[]) *}
	/*
		Registra a macro coletora nos eventos especificados.
		A partir desse momento, os eventos serão enviados para as respectivas portass.
	*/
	{* for event in events *}
		{{ EVENT.register(id='collector', event=event, overwrite=True) }}
	{* endfor *}
{* endmacro *}

{* macro remove_event_collectors(events=[]) *}
	/*
		Remove os coletores de eventos dos respectivos eventos.
	*/
	{* for event in events *}
		{{ EVENT.unregister(id='collector', event=event) }}
	{* endfor *}
{* endmacro *}

{* macro purge_event_queue(events=[]) *}
	/*
		Remove os elementos de uma fila de evento.
	*/
	{* for event in events *}
		{{ QUEUE.purge(port=PORTS[event]) }}
	{* endfor *}
{* endmacro *}

