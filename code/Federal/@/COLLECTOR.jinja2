{* block onWebSocketMessage *}
	{* set r = nid() *}
	SET(&json{{ r }},"{}")
	{{ JZON.add_or_update_key(json='%&json'~r~'%', path='CHANNEL', value='%CHANNEL%', outvar='&json'~r) }}
	{{ JZON.add_or_update_key(json='%&json'~r~'%', path='MESSAGE', value='%MESSAGE%', outvar='&json'~r) }}
	{{ QUEUE.add(content='%&json'~r~'%', subject='onWebSocketMessage', port=PORTS.onWebSocketMessage) }}
{* endblock *}