{* block onPickupItem *}
	{* set r = nid() *}
	SET(&json{{ r }},"{}");
	{{ JZON.add_or_update_key(json='%&json'~r~'%', path='ID', value='%PICKUPID%', outvar='&json'~r) }}
	{{ JZON.add_or_update_key(json='%&json'~r~'%', path='ITEM', value='%PICKUPITEM%', outvar='&json'~r) }}
	{{ JZON.add_or_update_key(json='%&json'~r~'%', path='DATA', value='%PICKUPDATA%', outvar='&json'~r) }}
	{{ JZON.add_or_update_key(json='%&json'~r~'%', path='AMOUNT', value='%PICKUPAMOUNT%', outvar='&json'~r) }}
	{{ QUEUE.add(content='%&json'~r~'%', subject='onPickupItem', port=PORTS.onPickupItem) }}
{* endblock *}

