      {* if 'roof' in layers *}
        {{ get(line='east-right',layer='roof',outvar='&'~prefix~'er'~loop.index0) }}
      {* endif *}
      {* if 'top' in layers *}
        {{ get(line='east-right',layer='top',outvar='&'~prefix~'et'~loop.index0) }}
      {* endif *}
    
    {* endif *}
    
  {* endfor *}
  
{* endmacro *}




  




