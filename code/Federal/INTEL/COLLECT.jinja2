{* import 'Federal.@.COLLECTOR' as COLLECTOR *}
{* import 'Federal.INTEL.QUEUE' as QUEUE *}
{* import 'Federal.INTEL.JZON' as JZON *}

{* set bind = COLLECTOR.add_event_collectors *}
{* set unbind = COLLECTOR.remove_event_collectors *}
{* set purge = COLLECTOR.purge_event_queue *}
{* set EVENT = COLLECTOR.EVENTS *}

{* macro default_collector(contentvar, timevar, port, read_only, index) *}
	{* set r = nid() *}
	{* if read_only *}
		{{ QUEUE.peek(subjectvar='&s'~r, contentvar=contentvar, timevar=timevar, port=port, index=index) }}
	{* else *}
		{{ QUEUE.poll(subjectvar='&s'~r, contentvar=contentvar, timevar=timevar, port=port, index=index) }}
	{* endif *}
{* endmacro *}

{* macro join_game(contentvar, timevar, read_only=False, index=0) *}
	{{ default_collector(contentvar=contentvar, timevar=timevar, port=COLLECTOR.PORTS.onJoinGame, read_only=read_only, index=index) }}
{* endmacro *}

