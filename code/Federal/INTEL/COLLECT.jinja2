{* macro pickup_item(idvar, itemvar, datavar, amountvar, timevar, read_only=False, index=0) *}
	{* set r = nid() *}
	UNSET(&c{{ r }});
	UNSET({{ idvar }});
	UNSET({{ itemvar }});
	UNSET({{ amountvar }});
	UNSET({{ timevar }});
	{{ default_collector(contentvar='&c'~r, timevar=timevar, port=COLLECTOR.PORTS.onPickupItem, read_only=read_only, index=index) }}
	IF(&c{{ r }});
		{!! JZON.key(json='%&c'~r~'%', key='ID', outvar=idvar) !!}
		{!! JZON.key(json='%&c'~r~'%', key='ITEM', outvar=itemvar) !!}
		{!! JZON.key(json='%&c'~r~'%', key='DATA', outvar=datavar) !!}
		{!! JZON.key(json='%&c'~r~'%', key='AMOUNT', outvar=amountvar) !!}
		{{ JZON.get_key_content(json='%&c'~r~'%', path='ID', outvar=idvar) }}
		{{ JZON.get_key_content(json='%&c'~r~'%', path='ITEM', outvar=itemvar) }}
		{{ JZON.get_key_content(json='%&c'~r~'%', path='DATA', outvar=datavar) }}
		{{ JZON.get_key_content(json='%&c'~r~'%', path='AMOUNT', outvar=amountvar) }}
		
	ENDIF;
{* endmacro *}

