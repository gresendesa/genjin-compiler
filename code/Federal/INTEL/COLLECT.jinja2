{* macro websocket_message(channelvar, messagevar, timevar, read_only=False, index=0) *}
	{* set r = nid() *}
	UNSET(&c{{ r }});
	UNSET({{ channelvar }});
	UNSET({{ messagevar }});
	UNSET({{ timevar }});
	{{ default_collector(contentvar='&c'~r, timevar=timevar, port=COLLECTOR.PORTS.onWebSocketMessage, read_only=read_only, index=index) }}
	IF(&c{{ r }});
		{!! JZON.key(json='%&c'~r~'%', key='CHANNEL', outvar=channelvar) !!}
		{!! JZON.key(json='%&c'~r~'%', key='MESSAGE', outvar=messagevar) !!}
		{{ JZON.get_key_content(json='%&c'~r~'%', path='CHANNEL', outvar=channelvar) }}
		{{ JZON.get_key_content(json='%&c'~r~'%', path='MESSAGE', outvar=messagevar) }}
	ENDIF;
{* endmacro *}
