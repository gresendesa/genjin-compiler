program "Fluxo Genérico de Testes"

vars {
    status_var: Number
}

procs {
    doe() from "tests.default.doe" {
        codes OK<0>, ERROR<1>
    }
    xpto() from "tests.default.xpto" {
        codes OK<0>, ERROR<1>
    }
    baz() from "tests.default.baz" {
        codes OK<0>, ERROR<1>
    }
    bar() from "tests.default.bar" {
        codes OK<0>, ERROR<1>, DEMORA<99>
    }
}


exec doe() >> status_var {
    case OK: 
        @xpto() when(OK)
        @baz() while(ERROR, DEMORA) when(OK)
        @bar()
    pass ERROR, OK
}

