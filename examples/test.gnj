program "Fluxo Genérico de Testes"

vars {
    status_var: Number
}

procs {
    inicia_processo() from "tests.default.xpto" {
        codes OK<0>, ERROR<1>
    }
}


exec inicia_processo() >> status_var {
    case OK: 
        @inicia_processo() while (OK)
        when(ERROR) @inicia_processo()
        when(OK) @inicia_processo()
    pass OK
} while(ERROR)

