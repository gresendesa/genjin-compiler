program "Fluxo Genérico de Testes"

vars {
    status_var: Number
}

procs {
    inicia_processo() from "tests.default.xpto" {
        codes OK<0>, ERROR<1>
    }
}


exec inicia_processo() >> status_var {
    case OK: exec inicia_processo() {
        pass ERROR, OK
    }
    pass ERROR, OK
} while(ERROR)

