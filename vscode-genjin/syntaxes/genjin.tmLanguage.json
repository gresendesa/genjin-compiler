{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Genjin",
  "scopeName": "source.genjin",
  "patterns": [
    { "include": "#comments" },
    { "include": "#program-declaration" },
    { "include": "#inline-call" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#codes-declaration" },
    { "include": "#operators" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "inline-call": {
      "comment": "Notação inline @proc() — açúcar sintático da SPR-2026-08",
      "match": "(@)([a-zA-Z_][a-zA-Z0-9_]*)(\\()(\\))",
      "captures": {
        "1": { "name": "keyword.operator.inline.genjin" },
        "2": { "name": "entity.name.function.genjin" },
        "3": { "name": "punctuation.definition.parameters.begin.genjin" },
        "4": { "name": "punctuation.definition.parameters.end.genjin" }
      }
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.genjin",
          "match": "//.*$"
        },
        {
          "name": "comment.block.genjin",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.genjin" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.genjin" }
          }
        }
      ]
    },
    "program-declaration": {
      "comment": "program \"nome do programa\"",
      "match": "\\b(program)\\b\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.genjin" },
        "2": { "name": "string.quoted.double.genjin" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "comment": "Palavras-chave de bloco/estrutura",
          "name": "keyword.control.genjin",
          "match": "\\b(vars|procs|exec|case|pass|while|when)\\b"
        },
        {
          "comment": "Palavras-chave de declaração",
          "name": "keyword.declaration.genjin",
          "match": "\\b(proc|from|as|codes)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.genjin",
      "match": "\\b(Number|Text|Logic)\\b"
    },
    "codes-declaration": {
      "comment": "Código de saída: NOME<numero>",
      "match": "\\b([A-Z_][A-Z0-9_]*)(<)(\\d+)(>)",
      "captures": {
        "1": { "name": "constant.other.exit-code.genjin" },
        "2": { "name": "punctuation.definition.angle.begin.genjin" },
        "3": { "name": "constant.numeric.integer.genjin" },
        "4": { "name": "punctuation.definition.angle.end.genjin" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.genjin",
          "match": ">>"
        },
        {
          "name": "keyword.operator.reference.genjin",
          "match": "&"
        },
        {
          "name": "keyword.operator.assignment.genjin",
          "match": "="
        },
        {
          "name": "punctuation.separator.genjin",
          "match": ","
        },
        {
          "name": "punctuation.separator.key-value.genjin",
          "match": ":"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.genjin",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.genjin" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.genjin" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.genjin",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.integer.genjin",
      "match": "\\b\\d+\\b"
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Constantes de código de saída (ALL_CAPS)",
          "name": "constant.other.exit-code.genjin",
          "match": "\\b[A-Z_][A-Z0-9_]*\\b"
        },
        {
          "comment": "Referência a módulo externo em strings dotted (Net.check)",
          "name": "entity.name.function.genjin",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)+\\b"
        },
        {
          "comment": "Identificadores gerais",
          "name": "variable.other.genjin",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
